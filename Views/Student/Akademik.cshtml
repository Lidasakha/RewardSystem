@model RewardSystem.Models.AkademikViewModel
@{
    ViewData["Title"] = "Akademik Panelim";
    ViewData["Active"] = "Akademik";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Tüm çalışmaları birleştir → tarih sıralı
    var tumCalisma = new List<(string Tur, string Baslik, string Detay, string Durum, DateTime? Tarih, string? Dosya, int? Puan, string? RedNeden)>();

    foreach (var m in Model.Makaleler)
        tumCalisma.Add(("Makale", m.Title ?? "", m.Journal ?? "", m.Status ?? "OnayBekliyor",
            m.Year.HasValue ? new DateTime(m.Year.Value, 1, 1) : (DateTime?)null, m.FilePath, m.Score, null));

    foreach (var p in Model.Projeler)
        tumCalisma.Add(("Proje", p.Title ?? "", p.Description ?? "", "OnayBekliyor",
            p.StartDate, p.FilePath, null, null));

    foreach (var b in Model.Bildiriler)
        tumCalisma.Add(("Sönum", b.Title ?? "", b.Conference ?? "", "OnayBekliyor",
            b.Year.HasValue ? new DateTime(b.Year.Value, 1, 1) : (DateTime?)null, b.FilePath, null, null));

    foreach (var pt in Model.Patentler)
        tumCalisma.Add(("Patent", pt.Title ?? "", pt.PatentNumber ?? "", "OnayBekliyor",
            pt.Year.HasValue ? new DateTime(pt.Year.Value, 1, 1) : (DateTime?)null, pt.FilePath, null, null));

    tumCalisma = tumCalisma.OrderByDescending(x => x.Tarih ?? DateTime.MinValue).ToList();

    int toplamOnay   = tumCalisma.Count(x => x.Durum == "Onaylandi");
    int toplamDeger  = tumCalisma.Count(x => x.Durum == "Degerlendirmede");
    int toplamRedde  = tumCalisma.Count(x => x.Durum == "Reddedildi");
    int toplamBekle  = tumCalisma.Count(x => x.Durum == "OnayBekliyor");
    int toplamToplam = tumCalisma.Count;
}

<style>
  .ak-page { display:flex; flex-direction:column; gap:20px; }

  /* Summary bar */
  .ak-summary {
    display:grid; grid-template-columns:repeat(5,1fr); gap:14px;
  }
  @@media(max-width:1100px){ .ak-summary { grid-template-columns:repeat(3,1fr); } }
  .ak-sum-card {
    background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius); padding:18px 20px;
    display:flex; align-items:center; gap:14px;
    box-shadow:var(--shadow-sm); transition:box-shadow .2s,transform .2s;
  }
  .ak-sum-card:hover { box-shadow:var(--shadow); transform:translateY(-2px); }
  .ak-sum-icon { width:44px; height:44px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
  .ak-sum-num  { font-size:26px; font-weight:800; color:var(--text); line-height:1; }
  .ak-sum-lbl  { font-size:12px; color:var(--text-muted); margin-top:2px; }

  /* Toolbar */
  .ak-toolbar {
    display:flex; gap:10px; align-items:center; flex-wrap:wrap;
    background:var(--surface); border:1px solid var(--border);
    border-radius:var(--radius); padding:14px 16px;
    box-shadow:var(--shadow-sm);
  }
  .ak-search {
    flex:1; min-width:200px; display:flex; align-items:center; gap:9px;
    background:var(--surface-2); border:1.5px solid var(--border);
    border-radius:var(--radius-sm); padding:0 14px;
    transition:border-color .18s,box-shadow .18s;
  }
  .ak-search:focus-within { border-color:var(--border-focus); box-shadow:0 0 0 3px rgba(74,112,196,.1); }
  .ak-search i { font-size:17px; color:var(--text-muted); flex-shrink:0; }
  .ak-search input {
    flex:1; border:none; outline:none; padding:10px 0;
    font-family:'Sora',sans-serif; font-size:13.5px; color:var(--text);
    background:transparent;
  }
  .ak-search input::placeholder { color:var(--text-light); }

  .ak-filter {
    padding:9px 14px; background:var(--surface-2);
    border:1.5px solid var(--border); border-radius:var(--radius-sm);
    font-family:'Sora',sans-serif; font-size:13px; color:var(--text);
    cursor:pointer; outline:none; transition:border-color .18s;
  }
  .ak-filter:focus { border-color:var(--border-focus); }

  .ak-new-btn {
    display:inline-flex; align-items:center; gap:7px;
    padding:10px 18px; border-radius:var(--radius-sm);
    background:var(--accent); color:#fff; border:none;
    font-family:'Sora',sans-serif; font-size:13px; font-weight:700;
    cursor:pointer; transition:all .18s; white-space:nowrap; text-decoration:none;
    box-shadow:0 2px 8px rgba(224,45,60,.25);
  }
  .ak-new-btn:hover { background:var(--accent-dark); transform:translateY(-1px); color:#fff; }

  /* List */
  .ak-list { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow-sm); overflow:hidden; }

  .ak-list-head {
    padding:14px 20px; border-bottom:1px solid var(--border);
    display:flex; align-items:center; justify-content:space-between;
    background:var(--surface-2);
  }
  .ak-list-head-title { font-size:13px; font-weight:700; color:var(--text); }
  .ak-count-badge { font-size:11px; font-weight:700; color:var(--text-muted); }

  /* Item */
  .ak-item {
    display:flex; align-items:flex-start; gap:14px;
    padding:16px 20px; border-bottom:1px solid var(--border);
    transition:background .15s; cursor:default;
  }
  .ak-item:last-child { border-bottom:none; }
  .ak-item:hover { background:var(--surface-2); }

  .ak-item-icon {
    width:42px; height:42px; border-radius:11px; flex-shrink:0;
    display:flex; align-items:center; justify-content:center; font-size:20px;
    margin-top:2px;
  }

  .ak-item-body { flex:1; min-width:0; }
  .ak-item-title { font-size:14px; font-weight:700; color:var(--text); margin-bottom:4px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .ak-item-meta  { font-size:12px; color:var(--text-muted); display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:6px; }
  .ak-item-meta i { font-size:13px; }

  .ak-item-right { display:flex; flex-direction:column; align-items:flex-end; gap:6px; flex-shrink:0; }

  /* Type pill */
  .ak-type {
    font-size:10.5px; font-weight:700; padding:3px 10px; border-radius:20px;
    white-space:nowrap;
  }
  .ak-type-makale  { background:var(--blue-bg);   color:var(--blue); }
  .ak-type-proje   { background:var(--green-bg);  color:var(--green); }
  .ak-type-sonum   { background:var(--yellow-bg); color:var(--yellow); }
  .ak-type-patent  { background:var(--purple-bg); color:var(--purple); }

  /* Status pill */
  .ak-status {
    font-size:10.5px; font-weight:700; padding:3px 10px; border-radius:20px;
    white-space:nowrap; display:inline-flex; align-items:center; gap:5px;
  }
  .ak-status-bekliyor      { background:var(--yellow-bg); color:var(--yellow); }
  .ak-status-degerlendirme { background:var(--blue-bg);   color:var(--blue); }
  .ak-status-onaylandi     { background:var(--green-bg);  color:var(--green); }
  .ak-status-reddedildi    { background:var(--red-bg);    color:var(--red); }

  .ak-status-dot { width:5px; height:5px; border-radius:50%; background:currentColor; display:inline-block; }

  /* File link */
  .ak-file-link {
    font-size:12px; font-weight:600; color:var(--blue);
    display:inline-flex; align-items:center; gap:4px; text-decoration:none;
  }
  .ak-file-link:hover { text-decoration:underline; }

  /* Score badge */
  .ak-score { font-size:11px; font-weight:700; color:var(--green); background:var(--green-bg); padding:3px 9px; border-radius:20px; }

  /* Empty */
  .ak-empty {
    padding:60px 20px; text-align:center; color:var(--text-muted);
  }
  .ak-empty i { font-size:48px; display:block; margin-bottom:14px; opacity:.25; }
  .ak-empty p { font-size:14px; margin-bottom:18px; }

  /* No results */
  .ak-no-results { padding:40px 20px; text-align:center; color:var(--text-muted); display:none; }
  .ak-no-results i { font-size:36px; display:block; margin-bottom:10px; opacity:.3; }

  @@media(max-width:700px){
    .ak-summary { grid-template-columns:1fr 1fr; }
    .ak-toolbar { flex-direction:column; align-items:stretch; }
    .ak-search { min-width:0; }
  }
  @@media(max-width:480px){
    .ak-summary { grid-template-columns:1fr; }
    .ak-item { flex-wrap:wrap; }
    .ak-item-right { flex-direction:row; align-items:center; width:100%; }
  }
</style>

<div class="ak-page">

  <!-- Summary -->
  <div class="ak-summary">
    <div class="ak-sum-card">
      <div class="ak-sum-icon" style="background:var(--blue-bg);color:var(--blue);"><i class="ti ti-files"></i></div>
      <div><div class="ak-sum-num">@toplamToplam</div><div class="ak-sum-lbl">Toplam Çalışma</div></div>
    </div>
    <div class="ak-sum-card">
      <div class="ak-sum-icon" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-circle-check"></i></div>
      <div><div class="ak-sum-num">@toplamOnay</div><div class="ak-sum-lbl">Onaylanan</div></div>
    </div>
    <div class="ak-sum-card">
      <div class="ak-sum-icon" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-clock"></i></div>
      <div><div class="ak-sum-num">@toplamBekle</div><div class="ak-sum-lbl">Bekleyen</div></div>
    </div>
    <div class="ak-sum-card">
      <div class="ak-sum-icon" style="background:var(--purple-bg);color:var(--purple);"><i class="ti ti-eye"></i></div>
      <div><div class="ak-sum-num">@toplamDeger</div><div class="ak-sum-lbl">Değerlendirilen</div></div>
    </div>
    <div class="ak-sum-card">
      <div class="ak-sum-icon" style="background:var(--red-bg);color:var(--red);"><i class="ti ti-circle-x"></i></div>
      <div><div class="ak-sum-num">@toplamRedde</div><div class="ak-sum-lbl">Reddedilen</div></div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="ak-toolbar">
    <div class="ak-search">
      <i class="ti ti-search"></i>
      <input type="text" id="akSearch" placeholder="Başlık, dergi, konferans ile ara..." oninput="akFilter()">
    </div>
    <select class="ak-filter" id="akTurFilter" onchange="akFilter()">
      <option value="">Tüm Türler</option>
      <option value="Makale">Makale</option>
      <option value="Proje">Proje</option>
      <option value="Sönum">Sönum</option>
      <option value="Patent">Patent</option>
    </select>
    <select class="ak-filter" id="akDurumFilter" onchange="akFilter()">
      <option value="">Tüm Durumlar</option>
      <option value="OnayBekliyor">Onay Bekliyor</option>
      <option value="Degerlendirmede">Değerlendirmede</option>
      <option value="Onaylandi">Onaylandı</option>
      <option value="Reddedildi">Reddedildi</option>
    </select>
  </div>

  <!-- List -->
  <div class="ak-list">
    <div class="ak-list-head">
      <span class="ak-list-head-title"><i class="ti ti-list-details" style="margin-right:7px;color:var(--accent);"></i>Çalışmalarım</span>
      <span class="ak-count-badge" id="akVisibleCount">@tumCalisma.Count çalışma</span>
    </div>

    @if (!tumCalisma.Any())
    {
      <div class="ak-empty">
        <i class="ti ti-file-off"></i>
        <p>Henüz hiç çalışma eklemediniz.</p>
        <a href="/Student/YeniCalisma" class="ak-new-btn" style="display:inline-flex;">
          <i class="ti ti-plus"></i> İlk Çalışmayı Ekle
        </a>
      </div>
    }
    else
    {
      <div id="akItemList">
        @foreach (var c in tumCalisma)
        {
          var turClass  = c.Tur == "Makale" ? "makale" : c.Tur == "Proje" ? "proje" : c.Tur == "Sönum" ? "sonum" : "patent";
          var iconClass = c.Tur == "Makale" ? "ti-file-text" : c.Tur == "Proje" ? "ti-layout-kanban" : c.Tur == "Sönum" ? "ti-speakerphone" : "ti-certificate";
          var iconBg    = c.Tur == "Makale" ? "var(--blue-bg);color:var(--blue)" : c.Tur == "Proje" ? "var(--green-bg);color:var(--green)" : c.Tur == "Sönum" ? "var(--yellow-bg);color:var(--yellow)" : "var(--purple-bg);color:var(--purple)";
          var durumClass = c.Durum == "Onaylandi" ? "onaylandi" : c.Durum == "Degerlendirmede" ? "degerlendirme" : c.Durum == "Reddedildi" ? "reddedildi" : "bekliyor";
          var durumText  = c.Durum == "Onaylandi" ? "Onaylandı" : c.Durum == "Degerlendirmede" ? "Değerlendirmede" : c.Durum == "Reddedildi" ? "Reddedildi" : "Onay Bekliyor";

          <div class="ak-item-wrap" data-tur="@c.Tur" data-durum="@c.Durum" data-title="@c.Baslik.ToLower()" data-detay="@c.Detay.ToLower()">
          <div class="ak-item @(c.Durum == "Reddedildi" ? "reddedildi" : "")" onclick="@(c.Durum == "Reddedildi" ? "toggleRedPanel(this)" : "")">
            <div class="ak-item-icon" style="background:@iconBg;">
              <i class="ti @iconClass"></i>
            </div>
            <div class="ak-item-body">
              <div class="ak-item-title">@c.Baslik</div>
              <div class="ak-item-meta">
                @if (!string.IsNullOrEmpty(c.Detay))
                {
                  <span><i class="ti ti-building"></i> @c.Detay</span>
                }
                @if (c.Tarih.HasValue)
                {
                  <span><i class="ti ti-calendar"></i> @c.Tarih.Value.Year</span>
                }
                @if (!string.IsNullOrEmpty(c.Dosya))
                {
                  <a href="@c.Dosya" target="_blank" class="ak-file-link">
                    <i class="ti ti-paperclip"></i> Dosyayı Gör
                  </a>
                }
              </div>
              <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
                <span class="ak-type ak-type-@turClass">@c.Tur</span>
                @if (c.Puan.HasValue && c.Durum == "Onaylandi")
                {
                  <span class="ak-score"><i class="ti ti-star" style="font-size:11px;"></i> @c.Puan Puan</span>
                }
              </div>
            </div>
            <div class="ak-item-right">
              <span class="ak-status ak-status-@durumClass">
                <span class="ak-status-dot"></span> @durumText
              </span>
              @if (c.Durum == "Reddedildi")
              {
                <i class="ti ti-chevron-down" style="font-size:14px;color:var(--red);margin-left:8px;transition:transform .2s;" class="red-chevron"></i>
              }
            </div>
          </div>
          @if (c.Durum == "Reddedildi")
          {
            <div class="ak-red-panel">
              <i class="ti ti-message-x" style="font-size:18px;color:var(--red);flex-shrink:0;margin-top:1px;"></i>
              <div>
                <div style="font-size:11px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.05em;margin-bottom:3px;">Red Sebebi</div>
                <div style="font-size:13.5px;color:var(--text);font-weight:500;line-height:1.5;">@(string.IsNullOrEmpty(c.RedNeden) ? "Yönetici tarafından red sebebi belirtilmemiş." : c.RedNeden)</div>
              </div>
            </div>
          }
          </div>
        }
      </div>
      <div class="ak-no-results" id="akNoResults">
        <i class="ti ti-search-off"></i>
        Aramanızla eşleşen çalışma bulunamadı.
      </div>
    }
  </div>

</div>

<script>
var _redTimers = {};
function toggleRedPanel(item) {
  var wrap  = item.closest('.ak-item-wrap');
  if (!wrap) return;
  var panel = wrap.querySelector('.ak-red-panel');
  if (!panel) return;
  var isOpen = panel.classList.contains('open');
  if (isOpen) {
    panel.classList.remove('open');
    panel.style.display = 'none';
    if (_redTimers[panel]) { clearTimeout(_redTimers[panel]); }
  } else {
    panel.classList.add('open');
    panel.style.display = 'flex';
    // 10 saniye sonra otomatik kapat
    _redTimers[panel] = setTimeout(function() {
      panel.classList.remove('open');
      panel.style.display = 'none';
    }, 10000);
  }
}

function akFilter() {
  var q      = document.getElementById('akSearch').value.toLowerCase().trim();
  var tur    = document.getElementById('akTurFilter').value;
  var durum  = document.getElementById('akDurumFilter').value;
  var items  = document.querySelectorAll('#akItemList .ak-item-wrap');
  var vis    = 0;

  items.forEach(function(item) {
    var title  = item.getAttribute('data-title') || '';
    var detay  = item.getAttribute('data-detay') || '';
    var itemTur   = item.getAttribute('data-tur') || '';
    var itemDurum = item.getAttribute('data-durum') || '';

    var matchQ     = !q    || title.includes(q) || detay.includes(q);
    var matchTur   = !tur  || itemTur === tur;
    var matchDurum = !durum || itemDurum === durum;

    var show = matchQ && matchTur && matchDurum;
    item.style.display = show ? '' : 'none';
    if (show) vis++;
  });

  var noRes = document.getElementById('akNoResults');
  if (noRes) noRes.style.display = vis === 0 ? 'block' : 'none';

  var cnt = document.getElementById('akVisibleCount');
  if (cnt) cnt.textContent = vis + ' çalışma';
}
</script>
