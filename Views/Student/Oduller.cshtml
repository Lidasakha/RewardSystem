@model List<RewardSystem.Models.Badge>
@{
    ViewData["Title"] = "Ödüllerim";
    ViewData["Active"] = "Oduller";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var toplamPuan     = (int)(ViewBag.ToplamPuan ?? 0);
    var tumOduller     = ViewBag.TumOduller as List<RewardSystem.Models.Reward> ?? new();
    var kazanilanAdlar = ViewBag.KazanilanAdlar as List<string> ?? new();
    var kilitliOduller = tumOduller.Where(o => !kazanilanAdlar.Contains(o.Name)).ToList();
}

<style>
.od-page { display:flex;flex-direction:column;gap:24px; }

/* Banner */
.od-banner {
  background:linear-gradient(135deg,#111827 0%,#1a2b4c 100%);
  border-radius:var(--radius-lg);padding:28px 32px;color:#fff;
  display:flex;align-items:center;justify-content:space-between;gap:20px;
  position:relative;overflow:hidden;
}
.od-banner::before{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.04);}
.od-banner::after{content:'';position:absolute;bottom:-40px;left:30%;width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,.03);}
.od-banner-left h2{font-size:22px;font-weight:800;margin-bottom:6px;}
.od-banner-left p{font-size:13px;color:rgba(255,255,255,.55);}
.od-banner-right{display:flex;gap:12px;z-index:1;flex-shrink:0;}
.od-stat{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:14px 22px;text-align:center;}
.od-stat-num{font-size:28px;font-weight:800;line-height:1;}
.od-stat-lbl{font-size:10px;color:rgba(255,255,255,.5);margin-top:4px;text-transform:uppercase;letter-spacing:.5px;}

/* Section header */
.od-section-hd{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;}
.od-section-hd::after{content:'';flex:1;height:1px;background:var(--border);}

/* Earned badges grid */
.od-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:16px;}

.od-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:24px 20px;text-align:center;box-shadow:var(--shadow-sm);
  transition:box-shadow .2s,transform .2s;position:relative;overflow:hidden;
}
.od-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;}
.od-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}

.od-icon{width:68px;height:68px;border-radius:18px;display:flex;align-items:center;justify-content:center;font-size:32px;margin:0 auto 16px;box-shadow:0 6px 20px rgba(0,0,0,.1);}
.od-card-name{font-size:15px;font-weight:800;color:var(--text);margin-bottom:5px;}
.od-card-desc{font-size:12.5px;color:var(--text-muted);line-height:1.5;margin-bottom:14px;}
.od-card-date{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--text-muted);background:var(--surface-2);padding:4px 12px;border-radius:20px;border:1px solid var(--border);}
.od-cert-btn{
  display:inline-flex;align-items:center;gap:6px;
  margin-top:12px;padding:9px 18px;border-radius:9px;
  font-family:'Sora',sans-serif;font-size:12px;font-weight:700;
  background:var(--brand-600);color:#fff;text-decoration:none;
  transition:all .18s;border:none;cursor:pointer;
}
.od-cert-btn:hover{background:var(--brand-700);transform:translateY(-1px);}

/* Empty earned state */
.od-empty{
  background:var(--surface);border:1px dashed var(--border);border-radius:var(--radius);
  padding:48px 20px;text-align:center;
}
.od-empty i{font-size:48px;display:block;margin-bottom:14px;opacity:.2;}
.od-empty-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:6px;}
.od-empty-sub{font-size:13px;color:var(--text-muted);}

/* Target / locked badges */
.od-target{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:18px 20px;display:flex;align-items:center;gap:16px;
  box-shadow:var(--shadow-sm);transition:box-shadow .15s;
}
.od-target:hover{box-shadow:var(--shadow);}
.od-target-icon{width:48px;height:48px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;background:var(--gray-100);color:var(--gray-400);}
body.dark-mode .od-target-icon{background:var(--gray-800);}
.od-target-name{font-size:13.5px;font-weight:700;color:var(--text);margin-bottom:2px;}
.od-target-req{font-size:11.5px;color:var(--text-muted);}
.od-target-prog{flex:1;}
.od-prog-bar{height:6px;background:var(--gray-100);border-radius:20px;overflow:hidden;margin:8px 0 4px;}
body.dark-mode .od-prog-bar{background:var(--gray-800);}
.od-prog-fill{height:100%;border-radius:20px;transition:width .6s ease;}
.od-prog-lbl{font-size:11px;color:var(--text-muted);}
.od-pct-badge{font-size:13px;font-weight:800;color:var(--text-muted);flex-shrink:0;min-width:40px;text-align:right;}
</style>

<div class="od-page">

  <!-- Banner -->
  <div class="od-banner">
    <div class="od-banner-left">
      <h2>🏆 Ödüllerim</h2>
      <p>Akademik çalışmalarınla kazandığın rozetler ve hedef ödüller.</p>
    </div>
    <div class="od-banner-right">
      <div class="od-stat">
        <div class="od-stat-num" style="color:#fbbf24;">@toplamPuan</div>
        <div class="od-stat-lbl">Toplam Puan</div>
      </div>
      <div class="od-stat">
        <div class="od-stat-num" style="color:#34d399;">@Model.Count</div>
        <div class="od-stat-lbl">Kazanılan</div>
      </div>
      @if (kilitliOduller.Any())
      {
        <div class="od-stat">
          <div class="od-stat-num" style="color:#a78bfa;">@kilitliOduller.Count</div>
          <div class="od-stat-lbl">Hedef</div>
        </div>
      }
    </div>
  </div>

  <!-- Kazanılan Ödüller -->
  <div class="od-section-hd">
    <i class="ti ti-trophy" style="color:#f59e0b;font-size:16px;"></i>
    Kazanılan Ödüller (@Model.Count)
  </div>

  @if (!Model.Any())
  {
    <div class="od-empty">
      <i class="ti ti-trophy"></i>
      <div class="od-empty-title">Henüz ödül kazanmadınız.</div>
      <div class="od-empty-sub">Akademik çalışmalarınızı gönderin ve puan kazanarak ödüllere ulaşın!</div>
    </div>
  }
  else
  {
    <div class="od-grid">
      @foreach (var b in Model)
      {
        var color = b.Color ?? "#f59e0b";
        <div class="od-card kazanildi" style="border-top-color:@color;">
          <div class="od-icon" style="background:@color+22;color:@color;">
            <i class="ti @(b.Icon ?? "ti-trophy")"></i>
          </div>
          <div class="od-card-name">@b.BadgeName</div>
          <div class="od-card-desc">@(b.Description ?? "Akademik başarı ödülü")</div>
          <div class="od-card-date">
            <i class="ti ti-calendar" style="font-size:13px;"></i>
            @b.EarnedAt.ToLocalTime().ToString("dd MMM yyyy")
          </div>
          <br>
          <a href="/Student/Sertifika/@b.Id" target="_blank" class="od-cert-btn">
            <i class="ti ti-certificate"></i> Sertifikayı Gör
          </a>
        </div>
      }
    </div>
  }

  <!-- Hedef Ödüller -->
  @if (kilitliOduller.Any())
  {
    <div class="od-section-hd" style="margin-top:4px;">
      <i class="ti ti-target" style="color:var(--accent);font-size:16px;"></i>
      Hedef Ödüller (@kilitliOduller.Count)
    </div>

    <div style="display:flex;flex-direction:column;gap:10px;">
      @foreach (var o in kilitliOduller)
      {
        var pct   = o.MinPoints > 0 ? Math.Min(100, (int)((double)toplamPuan / o.MinPoints * 100)) : 0;
        var kalan = Math.Max(0, o.MinPoints - toplamPuan);
        var color = o.Color ?? "#f59e0b";
        <div class="od-target">
          <div class="od-target-icon" style="@(pct >= 75 ? $"background:{color}22;color:{color};" : "")">
            <i class="ti @(pct >= 75 ? o.Icon : "ti-lock")"></i>
          </div>
          <div class="od-target-prog">
            <div class="od-target-name">@o.Name</div>
            <div class="od-target-req">@(o.Description ?? "") — @o.MinPoints puan gerekli</div>
            <div class="od-prog-bar">
              <div class="od-prog-fill" style="width:@pct%;background:@color;"></div>
            </div>
            <div class="od-prog-lbl">
              @toplamPuan / @o.MinPoints puan
              @if (kalan > 0) { <span>— @kalan puan daha gerekli</span> }
              else { <span style="color:var(--green);font-weight:700;">✓ Hedefe ulaştınız!</span> }
            </div>
          </div>
          <div class="od-pct-badge" style="@(pct > 0 ? $"color:{color};" : "")">@pct%</div>
        </div>
      }
    </div>
  }

</div>
