@model RewardSystem.Models.OgrenciDashboardViewModel
@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["Active"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var firstName = Model.Kullanici.FirstName ?? "Öğrenci";
    var lastName  = Model.Kullanici.LastName  ?? "";
    var initials  = (firstName.Length > 0 ? firstName[0].ToString() : "")
                  + (lastName.Length  > 0 ? lastName[0].ToString()  : "");
    var hour     = DateTime.Now.Hour;
    var greeting = hour < 6 ? "İyi geceler" : hour < 12 ? "Günaydın" : hour < 18 ? "İyi günler" : hour < 22 ? "İyi akşamlar" : "İyi geceler";
}
<style>
  :root { --blue:#1a5fa5; --blue-bg:#ebf3fb; }

  .dash { display:flex; flex-direction:column; gap:20px; }

  /* Welcome Card */
  .welcome {
    background:#111827;
    border-radius:var(--radius-lg); padding:26px 30px; color:#fff;
    display:flex; align-items:center; justify-content:space-between;
    position:relative; overflow:hidden;
  }
  .welcome::before{
    content:'';position:absolute;top:-60px;right:-60px;
    width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.06);
  }
  .welcome::after{
    content:'';position:absolute;bottom:-30px;right:90px;
    width:100px;height:100px;border-radius:50%;background:rgba(255,255,255,.04);
  }
  .welcome-text h2 { font-size:21px; font-weight:700; margin-bottom:4px; }
  .welcome-text p  { font-size:13.5px; color:rgba(255,255,255,.7); }
  .puan-box {
    text-align:center; z-index:1; flex-shrink:0;
    background:#111827;
    border:1px solid rgba(255,255,255,.08);
    border-radius:14px; padding:16px 28px;
  }
  .puan-num { font-size:40px; font-weight:800; line-height:1; color:#fff; }
  .puan-lbl { font-size:11px; color:rgba(255,255,255,.5); margin-top:4px; }
  body.dark-mode .puan-box { background:var(--accent); border-color:rgba(255,255,255,.1); }

  /* Stat cards */
  .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
  .sc {
    background:var(--surface); border:1px solid var(--border); border-radius:var(--radius);
    padding:18px; display:flex; align-items:flex-start; gap:12px;
    box-shadow:var(--shadow-sm); transition:box-shadow .2s,transform .2s;
  }
  .sc:hover { box-shadow:var(--shadow); transform:translateY(-2px); }
  .si {
    width:44px;height:44px;border-radius:10px;
    display:flex;align-items:center;justify-content:center;
    font-size:20px;flex-shrink:0;
  }
  .si.b{background:var(--blue-bg);color:var(--blue);}
  .si.g{background:var(--green-bg);color:var(--green);}
  .si.a{background:var(--yellow-bg);color:var(--yellow);}
  .si.p{background:var(--purple-bg);color:var(--purple);}
  .sc-num{font-size:26px;font-weight:800;color:var(--text);line-height:1;}
  .sc-lbl{font-size:12px;color:var(--text-muted);margin-top:3px;}
  .sc-badge{
    font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;
    margin-top:5px;display:inline-block;background:var(--gray-100);color:var(--gray-500);
  }

  /* Two col */
  .two { display:grid; grid-template-columns:1.5fr 1fr; gap:20px; }

  /* Submission rows */
  .sub-row {
    display:flex;align-items:center;gap:11px;
    padding:13px 18px; border-bottom:1px solid var(--border);
    transition:background .15s;
  }
  .sub-row:last-child{border-bottom:none;}
  .sub-row:hover{background:var(--surface-2);}
  .sub-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
  .sub-icon.mk{background:var(--blue-bg);color:var(--blue);}
  .sub-icon.pr{background:var(--green-bg);color:var(--green);}
  .sub-icon.bi{background:var(--yellow-bg);color:var(--yellow);}
  .sub-icon.pa{background:var(--purple-bg);color:var(--purple);}
  .sub-info{flex:1;min-width:0;}
  .sub-name{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .sub-meta{font-size:11px;color:var(--text-muted);margin-top:2px;}
  .sbadge{font-size:10.5px;font-weight:600;padding:3px 9px;border-radius:20px;white-space:nowrap;flex-shrink:0;}
  .sbadge.bekliyor{background:var(--yellow-bg);color:var(--yellow);}
  .sbadge.degerlendirme{background:var(--blue-bg);color:var(--blue);}
  .sbadge.onaylandi{background:var(--green-bg);color:var(--green);}
  .sbadge.reddedildi{background:var(--red-bg);color:var(--red);}

  /* Notification rows */
  .nr{
    display:flex;align-items:flex-start;gap:10px;
    padding:12px 16px;border-bottom:1px solid var(--border);
    text-decoration:none;transition:background .15s;
  }
  .nr:last-child{border-bottom:none;}
  .nr:hover{background:var(--surface-2);}
  .nr.unread{background:var(--blue-bg);}
  .nr.unread:hover{background:#dce8f7;}
  .nd{width:7px;height:7px;border-radius:50%;background:var(--blue);margin-top:5px;flex-shrink:0;}
  .nd-r{width:7px;flex-shrink:0;}
  .nr-msg{font-size:12px;color:var(--text);line-height:1.45;}
  .nr-time{font-size:10.5px;color:var(--text-muted);margin-top:2px;}

  /* CTA Footer */
  .cta-row{
    background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
    padding:18px 20px;display:flex;align-items:center;gap:16px;
    box-shadow:var(--shadow-sm);
  }
  .cta-icon{
    width:42px;height:42px;border-radius:10px;
    background:var(--blue-bg);color:var(--blue);
    display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;
  }
  .cta-text{flex:1;}
  .cta-text strong{font-size:13.5px;color:var(--text);display:block;}
  .cta-text span{font-size:11.5px;color:var(--text-muted);}
  .cta-btn{
    background:var(--brand-600);color:#fff;border:none;
    padding:9px 20px;border-radius:9px;font-size:13px;font-weight:700;
    cursor:pointer;text-decoration:none;transition:all .18s;white-space:nowrap;
    display:inline-flex;align-items:center;gap:7px;
    box-shadow:0 3px 10px rgba(26,43,76,.25);
  }
  .cta-btn:hover{background:var(--brand-700);transform:translateY(-1px);box-shadow:0 6px 18px rgba(26,43,76,.3);color:#fff;}
  body.dark-mode .cta-btn{background:var(--accent);box-shadow:0 3px 10px rgba(224,45,60,.3);}
  body.dark-mode .cta-btn:hover{background:var(--accent-dark);box-shadow:0 6px 18px rgba(224,45,60,.4);}

  .panel-head-badge{background:var(--accent);color:#fff;font-size:9.5px;font-weight:700;padding:1px 6px;border-radius:20px;}

  @@media(max-width:1100px){.stats{grid-template-columns:repeat(2,1fr)}.two{grid-template-columns:1fr;}}
  @@media(max-width:600px){.stats{grid-template-columns:1fr 1fr;}.welcome{flex-direction:column;gap:14px;}.puan-box{text-align:left;}}
</style>

<div class="dash">

  <!-- Welcome -->
  <div class="welcome">
    <div class="welcome-text">
      <h2>@greeting, @firstName! 👋</h2>
      <p>Akademik profilini ve çalışmalarını buradan takip edebilirsin.</p>
    </div>
    <div class="puan-box">
      <div class="puan-num">@Model.AkademikPuan</div>
      <div class="puan-lbl">Toplam Akademik Puan</div>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="sc">
      <div class="si b"><i class="ti ti-file-text"></i></div>
      <div><div class="sc-num">@Model.MakaleSayisi</div><div class="sc-lbl">Makale</div><span class="sc-badge">Gönderilen</span></div>
    </div>
    <div class="sc">
      <div class="si g"><i class="ti ti-layout-kanban"></i></div>
      <div><div class="sc-num">@Model.ProjeSayisi</div><div class="sc-lbl">Proje</div><span class="sc-badge">Gönderilen</span></div>
    </div>
    <div class="sc">
      <div class="si a"><i class="ti ti-speakerphone"></i></div>
      <div><div class="sc-num">@Model.BildiriSayisi</div><div class="sc-lbl">Bildiri</div><span class="sc-badge">Gönderilen</span></div>
    </div>
    <div class="sc">
      <div class="si p"><i class="ti ti-certificate"></i></div>
      <div><div class="sc-num">@Model.PatentSayisi</div><div class="sc-lbl">Patent</div><span class="sc-badge">Gönderilen</span></div>
    </div>
  </div>

  <!-- Two column -->
  <div class="two">
    <!-- Son Çalışmalar -->
    <div class="panel">
      <div class="panel-head">
        <span><i class="ti ti-clock-hour-4" style="color:var(--blue);margin-right:6px;"></i>Son Çalışmalar</span>
        <a class="see-all" asp-controller="Student" asp-action="Akademik">Tümünü Gör →</a>
      </div>
      @if (!Model.SonGonderiler.Any())
      {
        <div class="empty"><i class="ti ti-inbox" style="font-size:32px;opacity:.4;display:block;margin-bottom:8px;"></i>Henüz gönderilen çalışma bulunmuyor.</div>
      }
      else
      {
        @foreach (var g in Model.SonGonderiler)
        {
          var ic   = g.Tur switch { "Makale" => "mk", "Proje" => "pr", "Bildiri" => "bi", _ => "pa" };
          var icon = g.Tur switch { "Makale" => "ti-file-text", "Proje" => "ti-layout-kanban", "Bildiri" => "ti-speakerphone", _ => "ti-certificate" };
          var sc   = g.Status switch { "OnayBekliyor" => "bekliyor", "Degerlendirmede" => "degerlendirme", "Onaylandi" => "onaylandi", "Reddedildi" => "reddedildi", _ => "bekliyor" };
          var sl   = g.Status switch { "OnayBekliyor" => "Onay Bekliyor", "Degerlendirmede" => "Değerlendirmede", "Onaylandi" => "Onaylandı", "Reddedildi" => "Reddedildi", _ => g.Status };
          <div class="sub-row">
            <div class="sub-icon @ic"><i class="ti @icon"></i></div>
            <div class="sub-info">
              <div class="sub-name">@g.Baslik</div>
              <div class="sub-meta">@g.Tur · @(string.IsNullOrEmpty(g.TarihStr) ? g.Tarih.ToString("dd MMM yyyy") : g.TarihStr)</div>
            </div>
            <span class="sbadge @sc">@sl</span>
          </div>
        }
      }
    </div>

    <!-- Bildirimler -->
    <div class="panel">
      <div class="panel-head">
        <span>
          <i class="ti ti-bell" style="color:var(--blue);margin-right:6px;"></i>Bildirimler
          @if (Model.OkunmamisSayisi > 0)
          {
            <span class="panel-head-badge">@Model.OkunmamisSayisi yeni</span>
          }
        </span>
        <a class="see-all" asp-controller="Student" asp-action="Bildirimler">Tümünü Gör →</a>
      </div>
      @if (!Model.Bildirimler.Any())
      {
        <div class="empty"><i class="ti ti-bell-off" style="font-size:32px;opacity:.4;display:block;margin-bottom:8px;"></i>Yeni bildiriminiz yok.</div>
      }
      else
      {
        @foreach (var b in Model.Bildirimler)
        {
          <a class="nr @(!b.IsRead ? "unread" : "")" asp-controller="Student" asp-action="BildirimOkundu" asp-route-id="@b.Id">
            @if (!b.IsRead) { <div class="nd"></div> } else { <div class="nd-r"></div> }
            <div>
              <div class="nr-msg">@b.Message</div>
              <div class="nr-time">@b.CreatedAt.ToString("dd MMM, HH:mm")</div>
            </div>
          </a>
        }
      }
    </div>
  </div>

  <!-- CTA -->
  <div class="cta-row">
    <div class="cta-icon"><i class="ti ti-send"></i></div>
    <div class="cta-text">
      <strong>Yeni çalışma gönder</strong>
      <span>Makale, proje, bildiri veya patent ekleyerek akademik puanını artır.</span>
    </div>
    <a class="cta-btn" asp-controller="Student" asp-action="Akademik">
      <i class="ti ti-plus"></i> Gönder
    </a>
  </div>

</div>
