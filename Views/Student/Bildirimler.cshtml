@model List<RewardSystem.Models.Notification>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Bildirimler";
    ViewData["Active"] = "Bildirimler";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var okunmamis = Model.Count(b => !b.IsRead);
}

<style>
  .bd-page { display:flex;flex-direction:column;gap:16px; }
  .bd-panel { background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden; }
  .bd-head  { display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border);background:var(--surface-2); }
  .bd-head-left { display:flex;align-items:center;gap:10px;font-size:15px;font-weight:700;color:var(--text); }
  .bd-badge { background:var(--red-bg);color:var(--red);padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700; }
  .bd-all-read {
    display:inline-flex;align-items:center;gap:6px;
    padding:8px 16px;background:var(--surface);border:1.5px solid var(--border);
    border-radius:var(--radius-sm);font-family:'Sora',sans-serif;
    font-size:12.5px;font-weight:700;color:var(--text-muted);cursor:pointer;transition:all .15s;
  }
  .bd-all-read:hover { background:var(--green-bg);color:var(--green);border-color:rgba(22,163,74,.3); }

  .bd-item { display:flex;align-items:center;gap:14px;padding:16px 20px;border-bottom:1px solid var(--border);transition:background .15s; }
  .bd-item:last-child { border-bottom:none; }
  .bd-item.unread { background:var(--surface);border-left:3px solid var(--red); }
  .bd-item.read   { opacity:.75; }
  .bd-item:hover  { background:var(--surface-2); }

  .bd-dot { width:10px;height:10px;border-radius:50%;flex-shrink:0; }
  .bd-dot.unread { background:var(--red);animation:pulse 2s ease-in-out infinite; }
  .bd-dot.read   { background:var(--gray-300); }
  @@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}

  .bd-body  { flex:1;min-width:0; }
  .bd-msg   { font-size:13.5px;font-weight:600;color:var(--text);margin-bottom:4px;line-height:1.4; }
  .bd-time  { font-size:11.5px;color:var(--text-muted); }

  .bd-read-btn {
    flex-shrink:0;padding:7px 14px;
    background:var(--surface-2);border:1.5px solid var(--border);
    border-radius:var(--radius-sm);font-family:'Sora',sans-serif;
    font-size:12px;font-weight:700;color:var(--text-muted);cursor:pointer;transition:all .15s;
  }
  .bd-read-btn:hover { background:var(--green-bg);color:var(--green);border-color:rgba(22,163,74,.3); }

  .bd-empty { padding:60px 20px;text-align:center;color:var(--text-muted); }
  .bd-empty i { font-size:48px;display:block;margin-bottom:14px;opacity:.3; }
</style>

<div class="bd-page">
  <div class="bd-panel">
    <div class="bd-head">
      <div class="bd-head-left">
        <i class="ti ti-bell" style="font-size:18px;color:var(--accent);"></i>
        Bildirimler
        @if (okunmamis > 0)
        {
          <span class="bd-badge">@okunmamis okunmamış</span>
        }
      </div>
      @if (okunmamis > 0)
      {
        <form method="post" action="/Student/TumunuOku" style="display:inline;">
          @Html.AntiForgeryToken()
          <button type="submit" class="bd-all-read">
            <i class="ti ti-checks" style="font-size:15px;"></i> Tümünü Okundu İşaretle
          </button>
        </form>
      }
    </div>

    @if (!Model.Any())
    {
      <div class="bd-empty">
        <i class="ti ti-bell-off"></i>
        <p style="font-size:14px;font-weight:600;margin-bottom:6px;">Bildirim yok</p>
        <p style="font-size:13px;">Şu an için bildiriminiz bulunmuyor.</p>
      </div>
    }
    else
    {
      @foreach (var b in Model)
      {
        <div class="bd-item @(b.IsRead ? "read" : "unread")">
          <div class="bd-dot @(b.IsRead ? "read" : "unread")"></div>
          <div class="bd-body">
            <div class="bd-msg">@b.Message</div>
            <div class="bd-time">@b.CreatedAt.ToLocalTime().ToString("dd MMMM yyyy HH:mm", new System.Globalization.CultureInfo("tr-TR"))</div>
          </div>
          @if (!b.IsRead)
          {
            <form method="post" action="/Student/BildirimOkundu" style="display:inline;">
              @Html.AntiForgeryToken()
              <input type="hidden" name="id" value="@b.Id">
              <button type="submit" class="bd-read-btn">
                <i class="ti ti-check" style="font-size:13px;"></i> Okundu
              </button>
            </form>
          }
        </div>
      }
    }
  </div>
</div>
