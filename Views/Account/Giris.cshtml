@model RewardSystem.Models.LoginViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@{ Layout = null; }
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@Localizer["Login.Button"] — @Localizer["AppName"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --brand:#1a2b4c;--accent:#e02d3c;--accent-d:#b5202d;
      --bg:#f0f4f8;--surface:#fff;--border:#e2e8f0;
      --text:#0f172a;--muted:#64748b;--light:#94a3b8;
      --r:14px;--shadow:0 4px 24px rgba(0,0,0,.08);
    }
    body{
      font-family:'Sora',sans-serif;background:var(--bg);
      min-height:100vh;display:flex;align-items:center;justify-content:center;
      padding:24px;
    }

    /* Decorative blobs */
    body::before{
      content:'';position:fixed;width:600px;height:600px;border-radius:50%;
      background:radial-gradient(circle,rgba(26,43,76,.06) 0%,transparent 70%);
      top:-200px;right:-150px;pointer-events:none;
    }
    body::after{
      content:'';position:fixed;width:400px;height:400px;border-radius:50%;
      background:radial-gradient(circle,rgba(224,45,60,.06) 0%,transparent 70%);
      bottom:-120px;left:-100px;pointer-events:none;
    }

    .wrap{width:100%;max-width:420px;position:relative;z-index:1;}

    /* Brand */
    .brand{text-align:center;margin-bottom:28px;}
    .brand-logo{
      width:64px;height:64px;border-radius:18px;
      background:var(--brand);
      display:inline-flex;align-items:center;justify-content:center;
      font-size:18px;font-weight:800;color:#fff;
      box-shadow:0 8px 28px rgba(26,43,76,.25);margin-bottom:14px;
    }
    .brand h1{font-size:18px;font-weight:700;color:var(--text);letter-spacing:-.3px;}
    .brand p{font-size:13px;color:var(--muted);margin-top:4px;}

    /* Card */
    .card{background:var(--surface);border-radius:20px;padding:30px;border:1px solid var(--border);box-shadow:var(--shadow);}
    .card-title{font-size:21px;font-weight:700;color:var(--text);letter-spacing:-.5px;margin-bottom:4px;}
    .card-sub{font-size:13.5px;color:var(--muted);margin-bottom:24px;}

    /* Form */
    .fg{margin-bottom:16px;}
    .fg label{display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:7px;letter-spacing:.02em;}
    .input-wrap{position:relative;}
    .input-wrap i{
      position:absolute;left:12px;top:50%;transform:translateY(-50%);
      font-size:17px;color:var(--light);pointer-events:none;
    }
    .fg input{
      width:100%;padding:11px 14px 11px 40px;
      border:1.5px solid var(--border);border-radius:10px;
      font-family:'Sora',sans-serif;font-size:14px;color:var(--text);
      background:#fafcfb;outline:none;transition:border-color .18s,box-shadow .18s;
    }
    .fg input:focus{border-color:var(--brand);background:#fff;box-shadow:0 0 0 3px rgba(26,43,76,.08);}
    .fg input::placeholder{color:var(--light);}

    /* Options row */
    .opts{display:flex;align-items:center;justify-content:space-between;margin:-4px 0 20px;}
    .rem{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--muted);cursor:pointer;}
    .rem input{accent-color:var(--accent);}
    .forgot a{font-size:12.5px;color:var(--brand);font-weight:600;transition:opacity .15s;}
    .forgot a:hover{opacity:.7;}

    /* Submit */
    .btn-submit{
      width:100%;padding:13px;
      background:var(--brand);color:#fff;border:none;
      border-radius:10px;font-family:'Sora',sans-serif;
      font-size:14.5px;font-weight:700;cursor:pointer;
      transition:all .2s;box-shadow:0 4px 16px rgba(26,43,76,.25);
      display:flex;align-items:center;justify-content:center;gap:8px;
    }
    .btn-submit:hover{background:var(--accent);box-shadow:0 6px 22px rgba(224,45,60,.3);transform:translateY(-1px);}

    /* Divider */
    .divider{display:flex;align-items:center;gap:12px;margin:20px 0;color:var(--light);font-size:12px;}
    .divider::before,.divider::after{content:'';flex:1;height:1px;background:var(--border);}

    /* Register link */
    .reg-link{text-align:center;font-size:13px;color:var(--muted);}
    .reg-link a{color:var(--brand);font-weight:700;transition:color .15s;}
    .reg-link a:hover{color:var(--accent);}

    /* Alerts */
    .err{background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:11px 14px;font-size:13px;color:#dc2626;margin-bottom:16px;}
    .suc{background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;padding:11px 14px;font-size:13px;color:#16a34a;margin-bottom:16px;}

    /* Footer */
    .footer{text-align:center;margin-top:20px;font-size:11.5px;color:var(--light);}
  </style>
</head>
<body>
<div class="wrap">
  <div class="brand">
    <div class="brand-logo">TÖ</div>
    <h1>@Localizer["AppFullName"]</h1>
    <p>@Localizer["AppDesc"]</p>
  </div>

  <div class="card">
    <div class="card-title">@Localizer["Login.Title"]</div>
    <div class="card-sub">@Localizer["Login.Subtitle"]</div>

    @if (ViewData.ModelState.ErrorCount > 0)
    {
      <div class="err">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        { <div>@err.ErrorMessage</div> }
      </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
      <div class="suc">@TempData["SuccessMessage"]</div>
    }

    <form asp-action="Giris" method="post">
      @Html.AntiForgeryToken()

      <div class="fg">
        <label>@Localizer["Login.Username"]</label>
        <div class="input-wrap">
          <i class="ti ti-user"></i>
          <input asp-for="Username" placeholder="@Localizer["Login.Username"]" autocomplete="username">
        </div>
      </div>

      <div class="fg">
        <label>@Localizer["Login.Password"]</label>
        <div class="input-wrap">
          <i class="ti ti-lock"></i>
          <input asp-for="Password" type="password" placeholder="@Localizer["Login.Password"]" autocomplete="current-password">
        </div>
      </div>

      <div class="opts">
        <label class="rem">
          <input asp-for="RememberMe" type="checkbox"> @Localizer["Login.Remember"]
        </label>
        <div class="forgot"><a asp-action="SifremiUnuttum">@Localizer["Login.Forgot"]</a></div>
      </div>

      <button type="submit" class="btn-submit">
        <i class="ti ti-login"></i> @Localizer["Login.Button"]
      </button>
    </form>

    <div class="divider">@Localizer["Login.Or"]</div>

    <div class="reg-link">
      @Localizer["Login.NoAccount"] <a asp-action="KayitOl">@Localizer["Login.Register"]</a>
    </div>
  </div>

  <div class="footer">© 2025 Teşvik ve Ödüllendirme Sistemi · Tüm hakları saklıdır.</div>
</div>
</body>
</html>
