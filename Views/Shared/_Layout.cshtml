@using RewardSystem.Data
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject RewardSystemDbContext _db
@{
    var rol         = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value?.ToLower();
    var adSoyad     = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
    var kullaniciAdi= User.FindFirst("Username")?.Value;
    var initials    = adSoyad?.Length > 0
                        ? adSoyad.Split(' ').Select(s => s[0]).Take(2)
                                 .Aggregate("", (c, n) => c + n).ToUpper()
                        : "U";
    var firstLetter = adSoyad?.Length > 0 ? adSoyad[0].ToString() : "U";

    int userId = 0;
    int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out userId);

    int stat1 = 0, stat2 = 0, stat3 = 0;
    decimal stat3Dec = 0;

    if (rol == "ogrenci" && userId > 0)
    {
        stat1    = _db.Articles.Count(a => a.UserId == userId) + _db.Projects.Count(p => p.UserId == userId) + _db.Presentations.Count(b => b.UserId == userId);
        stat2    = _db.Articles.Count(a => a.UserId == userId && a.Status == "OnayBekliyor");
        stat3Dec = _db.Articles.Where(a => a.UserId == userId && a.Status == "Onaylandi").Sum(a => (int?)a.Score) ?? 0;
    }
    else if (userId > 0)
    {
        stat1 = _db.ArticleTeacherAssignments.Count(a => a.TeacherId == userId);
        stat2 = _db.Articles.Count(a => a.Status == "OnayBekliyor");
        stat3 = _db.Users.Count(u => u.UserType != null && u.UserType.ToLower() == "ogrenci" && u.IsActive);
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>@ViewData["Title"] — TÖS</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css">
  <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
<script>
  (function(){
    var t = localStorage.getItem('theme');
    if(t==='dark'||(!t&&window.matchMedia('(prefers-color-scheme:dark)').matches)){
      document.body.classList.add('dark-mode');
    }
  })();
</script>

<div class="app">
  <!-- ═══ SIDEBAR ═══ -->
  <aside class="sidebar" id="sidebar">

    <!-- Logo -->
    <div class="sidebar-logo">
      <div style="width:34px;height:34px;background:var(--accent);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#fff;flex-shrink:0;">TÖ</div>
      <div class="sidebar-logo-text">
        @Localizer["AppName"]
        <span class="sidebar-logo-sub">@Localizer["AppFullName"]</span>
      </div>
    </div>

    <!-- User Card -->
    <div class="user-card">
      <div class="avatar">@firstLetter</div>
      <div class="user-info">
        <div class="user-name">@adSoyad</div>
        <div class="user-role">
          @if (rol == "ogrenci")         { <span>@Localizer["Role.Student"]</span> }
          else if (rol == "teacher")     { <span>@Localizer["Role.Teacher"]</span> }
          else if (rol == "admin")       { <span>@Localizer["Role.Admin"]</span> }
          else if (rol == "superadmin")  { <span>@Localizer["Role.SuperAdmin"]</span> }
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="nav">
      @if (rol == "ogrenci")
      {
        <div class="nav-section">Ana Menü</div>
        <a href="/Student/Index" class="nav-item @(ViewData["Active"]?.ToString()=="Home"?"active":"")">
          <i class="ti ti-home"></i><span>@Localizer["Menu.Home"]</span>
        </a>

        <div class="nav-section">@Localizer["Menu.AcademicWorks"]</div>
        <a href="/Student/Akademik" class="nav-item @(ViewData["Active"]?.ToString()=="Akademik"?"active":"")">
          <i class="ti ti-file-text"></i>@Localizer["Menu.AcademicWorks"]
        </a>
        <a href="/Student/YeniCalisma" class="nav-item @(ViewData["Active"]?.ToString()=="YeniCalisma"?"active":"")">
          <i class="ti ti-circle-plus"></i>@Localizer["Menu.NewWork"]
        </a>
        <a href="/Student/Siralama" class="nav-item @(ViewData["Active"]?.ToString()=="Siralama"?"active":"")">
          <i class="ti ti-trophy"></i>@Localizer["Menu.Ranking"]
        </a>

        <div class="nav-section">Diğer</div>
        <a href="/Student/Bildirimler" class="nav-item @(ViewData["Active"]?.ToString()=="Bildirimler"?"active":"")">
          <i class="ti ti-bell"></i>@Localizer["Menu.Notifications"]
        </a>
      }
      else if (rol == "admin" || rol == "teacher" || rol == "superadmin")
      {
        <div class="nav-section">Ana Menü</div>
        <a href="/Admin/Index" class="nav-item @(ViewData["Active"]?.ToString()=="Home"?"active":"")">
          <i class="ti ti-layout-dashboard"></i>@Localizer["Menu.Home"]
        </a>
        <a href="/Admin/Ogrenciler" class="nav-item @(ViewData["Active"]?.ToString()=="Ogrenciler"?"active":"")">
          <i class="ti ti-users"></i>@Localizer["Menu.Students"]
        </a>

        @if (rol != "superadmin")
        {
          <div class="nav-section">Akademik</div>
          <a href="/Admin/Degerlendirmelerim" class="nav-item @(ViewData["Active"]?.ToString()=="Degerlendirmelerim"?"active":"")">
            <i class="ti ti-clipboard-check"></i>@Localizer["Menu.Evaluations"]
          </a>
          <a href="/Admin/BolumSiralama" class="nav-item @(ViewData["Active"]?.ToString()=="BolumSiralama"?"active":"")">
            <i class="ti ti-trophy"></i>@Localizer["Menu.DeptRanking"]
          </a>
          <a href="/Admin/BolumRaporlar" class="nav-item @(ViewData["Active"]?.ToString()=="BolumRaporlar"?"active":"")">
            <i class="ti ti-chart-bar"></i>@Localizer["Menu.DeptReports"]
          </a>
        }

        @if (rol == "superadmin")
        {
          <a href="/Admin/OnayBekleyenOgrenciler" class="nav-item @(ViewData["Active"]?.ToString()=="OnayBekleyenOgrenciler"?"active":"")">
            <i class="ti ti-user-check"></i>@Localizer["Menu.StudentApprovals"]
          </a>
          <div class="nav-section">Akademik</div>
          <a href="/Admin/AdminYonetimi" class="nav-item @(ViewData["Active"]?.ToString()=="AdminYonetimi"?"active":"")">
            <i class="ti ti-settings-2"></i>@Localizer["Menu.AcademicManagement"]
          </a>
          <div class="nav-section">Sistem</div>
          <a href="/Admin/Raporlar" class="nav-item @(ViewData["Active"]?.ToString()=="Raporlar"?"active":"")">
            <i class="ti ti-chart-bar"></i><span>Raporlar & İstatistikler</span>
          </a>
          <a href="/Admin/KullaniciYonetimi" class="nav-item @(ViewData["Active"]?.ToString()=="KullaniciYonetimi"?"active":"")">
            <i class="ti ti-users-group"></i>@Localizer["Menu.UserManagement"]
          </a>
        }
      }
    </nav>

    <!-- Logout -->
    <form asp-controller="Account" asp-action="Cikis" method="post" style="padding:0;">
      @Html.AntiForgeryToken()
      <button type="submit" class="logout-btn" style="width:100%;text-align:left;">
        <i class="ti ti-logout"></i><span>@Localizer["Logout"]</span>
      </button>
    </form>
  </aside>

  <!-- Overlay (mobile) -->
  <div class="overlay" id="overlay"></div>

  <!-- ═══ MAIN ═══ -->
  <div class="main">

    <!-- Topbar -->
    <header class="topbar">
      <button class="hamburger" onclick="toggleSidebar()" aria-label="Menüyü aç/kapat">
        <i class="ti ti-menu-2"></i>
      </button>

      <div class="topbar-title">@ViewData["Title"]</div>

      <div class="topbar-right">
        <!-- Language Switcher -->
        <div class="lang-switch">
          @{ var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName; }
          <a href="/Language/Set/tr?returnUrl=@Context.Request.Path"
             class="lang-btn @(currentCulture == "tr" ? "active" : "")"
             title="Türkçe">🇹🇷 TR</a>
          <a href="/Language/Set/en?returnUrl=@Context.Request.Path"
             class="lang-btn @(currentCulture == "en" ? "active" : "")"
             title="English">🇬🇧 EN</a>
        </div>

        <!-- Theme Toggle -->
        <button class="theme-toggle" id="themeToggleBtn" aria-label="Tema değiştir">
          <i class="ti ti-sun" id="themeIcon"></i>
        </button>

        <!-- User Dropdown -->
        <div class="user-dropdown-wrapper">
          <button class="topbar-user" onclick="toggleRightPanel(event)">
            <div class="topbar-avatar">@initials</div>
            <span class="topbar-username">@kullaniciAdi</span>
            <i class="ti ti-chevron-down" style="font-size:13px;color:var(--text-muted);"></i>
          </button>

          <!-- Dropdown -->
          <div class="pnd-profile-dropdown" id="pndRightPanel">
            <div class="hesabim-inner">

              <!-- Profile Card -->
              <div class="profile-card">
                <div class="hero">
                  <div class="avatar-large">@initials</div>
                  <div class="hero-name">@adSoyad</div>
                  <div class="badge role-badge">
                    @if (rol == "ogrenci")       { <i class="ti ti-school"></i><span>Öğrenci</span> }
                    else if (rol == "teacher")   { <i class="ti ti-book"></i><span>Öğretmen</span> }
                    else if (rol == "admin")     { <i class="ti ti-shield"></i><span>Admin</span> }
                    else if (rol == "superadmin"){ <i class="ti ti-bolt"></i><span>Süper Admin</span> }
                  </div>
                </div>

                <div class="stats-row">
                  @if (rol == "ogrenci")
                  {
                    <div class="stat"><div class="stat-num">@stat1</div><div class="stat-lbl">Gönderilen</div></div>
                    <div class="stat"><div class="stat-num">@stat2</div><div class="stat-lbl">Süreçte</div></div>
                    <div class="stat"><div class="stat-num">@stat3Dec</div><div class="stat-lbl">Ort. Puan</div></div>
                  }
                  else
                  {
                    <div class="stat"><div class="stat-num">@stat1</div><div class="stat-lbl">Değerlendirme</div></div>
                    <div class="stat"><div class="stat-num">@stat2</div><div class="stat-lbl">Bekleyen</div></div>
                    <div class="stat"><div class="stat-num">@stat3</div><div class="stat-lbl">Aktif</div></div>
                  }
                </div>
              </div>

              <!-- Menu -->
              <div class="section-label">Hesap</div>
              <div class="menu-card">
                <a class="menu-item" href="/Profile/Index">
                  <div class="menu-icon icon-navy"><i class="ti ti-user"></i></div>
                  <div class="menu-text">
                    <div class="menu-title">Profili Düzenle</div>
                    <div class="menu-sub">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</div>
                  </div>
                  <i class="ti ti-chevron-right menu-arrow"></i>
                </a>
                @if (rol == "ogrenci")
                {
                  <a class="menu-item" href="/Student/Akademik">
                    <div class="menu-icon icon-green"><i class="ti ti-file-upload"></i></div>
                    <div class="menu-text">
                      <div class="menu-title">Yeni Çalışma Ekle</div>
                      <div class="menu-sub">Makale, proje veya bildiri</div>
                    </div>
                    <i class="ti ti-chevron-right menu-arrow"></i>
                  </a>
                }
              </div>

              <!-- Logout -->
              <form class="logout-form" asp-controller="Account" asp-action="Cikis" method="post">
                @Html.AntiForgeryToken()
                <button type="submit">
                  <i class="ti ti-logout"></i>@Localizer["Logout"]
                </button>
              </form>

            </div>
          </div>
        </div><!-- /user-dropdown-wrapper -->
      </div><!-- /topbar-right -->
    </header>

    <!-- Page Content -->
    <div class="content">
      @RenderBody()
    </div>
  </div>
</div>

<script src="~/js/site.js"></script>
<script>
  // ── Theme ──────────────────────────────────────────────
  const themeBtn  = document.getElementById('themeToggleBtn');
  const themeIcon = document.getElementById('themeIcon');

  function applyThemeIcon() {
    const dark = document.body.classList.contains('dark-mode');
    themeIcon.className = dark ? 'ti ti-moon' : 'ti ti-sun';
    themeBtn.title = dark ? 'Aydınlık moda geç' : 'Karanlık moda geç';
  }

  applyThemeIcon();

  themeBtn.addEventListener('click', function () {
    document.body.classList.toggle('dark-mode');
    const isDark = document.body.classList.contains('dark-mode');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    applyThemeIcon();
  });

  // ── Dropdown ───────────────────────────────────────────
  function toggleRightPanel(e) {
    if (e) e.stopPropagation();
    document.getElementById('pndRightPanel').classList.toggle('open');
  }

  document.addEventListener('click', function (e) {
    const panel   = document.getElementById('pndRightPanel');
    const wrapper = document.querySelector('.user-dropdown-wrapper');
    if (panel && panel.classList.contains('open') && wrapper && !wrapper.contains(e.target)) {
      panel.classList.remove('open');
    }
  });
</script>
</body>
</html>
