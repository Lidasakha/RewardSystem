@{
    ViewData["Title"] = "Admin Paneli";
    ViewData["Active"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
  .admin-dash { display:flex; flex-direction:column; gap:20px; }

  .welcome-banner {
    background: linear-gradient(135deg, var(--brand-600) 0%, #0a1e3d 100%);
    border-radius: var(--radius-lg);
    padding: 26px 30px;
    color: #fff;
    display: flex; align-items: center; justify-content: space-between;
    position: relative; overflow: hidden;
  }
  .welcome-banner::before {
    content:''; position:absolute; top:-60px; right:-60px;
    width:220px; height:220px; border-radius:50%;
    background:rgba(255,255,255,.05);
  }
  .welcome-banner::after {
    content:''; position:absolute; bottom:-40px; right:60px;
    width:120px; height:120px; border-radius:50%;
    background:rgba(255,255,255,.04);
  }
  .welcome-text h2 { font-size:20px; font-weight:700; margin-bottom:4px; }
  .welcome-text p  { font-size:13px; color:rgba(255,255,255,.65); }
  .welcome-actions { display:flex; gap:10px; flex-shrink:0; z-index:1; }
  .wb-btn {
    display:inline-flex; align-items:center; gap:7px;
    padding:9px 18px; border-radius:10px; font-size:13px; font-weight:700;
    cursor:pointer; transition:all .18s; text-decoration:none; border:none;
  }
  .wb-btn-primary { background:#fff; color:var(--brand-600); }
  .wb-btn-primary:hover { background:var(--accent); color:#fff; }
  .wb-btn-secondary { background:rgba(255,255,255,.12); color:#fff; border:1px solid rgba(255,255,255,.2); }
  .wb-btn-secondary:hover { background:rgba(255,255,255,.2); }

  /* Stat cards row */
  .admin-stats { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  .a-stat {
    background:var(--surface); border:1px solid var(--border); border-radius:var(--radius);
    padding:20px; display:flex; align-items:center; gap:16px;
    box-shadow:var(--shadow-sm); transition:box-shadow .18s, transform .18s;
  }
  .a-stat:hover { box-shadow:var(--shadow); transform:translateY(-2px); }
  .a-stat-icon {
    width:52px; height:52px; border-radius:14px; flex-shrink:0;
    display:flex; align-items:center; justify-content:center; font-size:24px;
  }
  .a-stat-num  { font-size:30px; font-weight:800; color:var(--text); line-height:1; }
  .a-stat-lbl  { font-size:12px; color:var(--text-muted); margin-top:3px; }

  /* Two column */
  .admin-grid { display:grid; grid-template-columns:1fr 300px; gap:20px; }

  /* Quick actions */
  .quick-actions { display:flex; flex-direction:column; gap:10px; padding:16px; }
  .qa-btn {
    display:flex; align-items:center; gap:12px;
    padding:14px 16px; border-radius:var(--radius-sm);
    text-decoration:none; transition:all .18s;
    border:1px solid var(--border);
  }
  .qa-btn-icon {
    width:40px; height:40px; border-radius:10px;
    display:flex; align-items:center; justify-content:center;
    font-size:20px; flex-shrink:0;
  }
  .qa-btn-text strong { display:block; font-size:13.5px; font-weight:700; color:var(--text); }
  .qa-btn-text span   { font-size:11.5px; color:var(--text-muted); }
  .qa-btn:hover { background:var(--surface-2); border-color:var(--gray-300); }

  @@media(max-width:900px){
    .admin-stats { grid-template-columns:1fr 1fr; }
    .admin-grid  { grid-template-columns:1fr; }
    .welcome-actions { display:none; }
  }
  @@media(max-width:600px){
    .admin-stats { grid-template-columns:1fr; }
  }
</style>

<div class="admin-dash">

  <!-- Welcome Banner -->
  <div class="welcome-banner">
    <div class="welcome-text">
      <h2>Yönetim Paneli</h2>
      <p>Bekleyen işlemler ve sistem durumu buradan takip edilir.</p>
    </div>
    @if (User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value?.ToLower() == "superadmin")
    {
      <div class="welcome-actions">
        <a href="/Admin/OnayBekleyenOgrenciler" class="wb-btn wb-btn-primary">
          <i class="ti ti-user-check"></i> Öğrenci Onayla
        </a>
        <a href="/Admin/AdminYonetimi" class="wb-btn wb-btn-secondary">
          <i class="ti ti-settings-2"></i> Yönetim
        </a>
      </div>
    }
  </div>

  <!-- Stat Cards -->
  <div class="admin-stats">
    <div class="a-stat">
      <div class="a-stat-icon" style="background:var(--yellow-bg);color:var(--yellow);">
        <i class="ti ti-file-time"></i>
      </div>
      <div>
        <div class="a-stat-num">@ViewBag.PendingArticles</div>
        <div class="a-stat-lbl">Bekleyen Çalışma</div>
      </div>
    </div>
    <div class="a-stat">
      <div class="a-stat-icon" style="background:var(--blue-bg);color:var(--blue);">
        <i class="ti ti-user-question"></i>
      </div>
      <div>
        <div class="a-stat-num">@ViewBag.PendingStudents</div>
        <div class="a-stat-lbl">Onay Bekleyen Öğrenci</div>
      </div>
    </div>
    <div class="a-stat">
      <div class="a-stat-icon" style="background:var(--green-bg);color:var(--green);">
        <i class="ti ti-users"></i>
      </div>
      <div>
        <div class="a-stat-num">@ViewBag.TotalActiveStudents</div>
        <div class="a-stat-lbl">Aktif Öğrenci</div>
      </div>
    </div>
  </div>

  <!-- Main Grid -->
  <div class="admin-grid">
    <!-- Pending Articles -->
    <div class="panel">
      <div class="panel-head">
        <span><i class="ti ti-file-time" style="color:var(--yellow);margin-right:6px;"></i>Son Bekleyen Çalışmalar</span>
        <a href="/Admin/AdminYonetimi" class="see-all">Tümünü Yönet →</a>
      </div>
      @if (ViewBag.RecentPendingArticles == null || !((List<RewardSystem.Models.Article>)ViewBag.RecentPendingArticles).Any())
      {
        <div class="empty"><i class="ti ti-checks" style="font-size:32px;color:var(--green);display:block;margin-bottom:8px;"></i>Bekleyen çalışma bulunmuyor.</div>
      }
      else
      {
        @foreach (var a in (List<RewardSystem.Models.Article>)ViewBag.RecentPendingArticles)
        {
          <div class="list-item">
            <div class="list-icon" style="width:36px;height:36px;background:var(--yellow-bg);border-radius:9px;display:flex;align-items:center;justify-content:center;">
              <i class="ti ti-file-text" style="color:var(--yellow);font-size:18px;"></i>
            </div>
            <div class="list-info">
              <div class="list-title">@a.Title</div>
              <div class="list-sub"><i class="ti ti-user" style="font-size:11px;"></i> @a.User?.FullName · @(a.Year ?? 0)</div>
            </div>
            <span class="badge-yellow">Bekliyor</span>
          </div>
        }
      }
    </div>

    <!-- Quick Actions -->
    <div class="panel">
      <div class="panel-head"><span>Hızlı İşlemler</span></div>
      <div class="quick-actions">
        <a href="/Admin/OnayBekleyenOgrenciler" class="qa-btn">
          <div class="qa-btn-icon" style="background:var(--blue-bg);color:var(--blue);"><i class="ti ti-user-check"></i></div>
          <div class="qa-btn-text">
            <strong>Öğrenci Onayları</strong>
            <span>Kayıt bekleyenleri onayla</span>
          </div>
        </a>
        <a href="/Admin/AdminYonetimi" class="qa-btn">
          <div class="qa-btn-icon" style="background:var(--purple-bg);color:var(--purple);"><i class="ti ti-clipboard-check"></i></div>
          <div class="qa-btn-text">
            <strong>Makale Değerlendirme</strong>
            <span>Gelen çalışmaları değerlendir</span>
          </div>
        </a>
        <a href="/Admin/Ogrenciler" class="qa-btn">
          <div class="qa-btn-icon" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-users"></i></div>
          <div class="qa-btn-text">
            <strong>Öğrenci Listesi</strong>
            <span>Tüm öğrencileri görüntüle</span>
          </div>
        </a>
        <a href="/Admin/KullaniciYonetimi" class="qa-btn">
          <div class="qa-btn-icon" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-settings-2"></i></div>
          <div class="qa-btn-text">
            <strong>Kullanıcı Yönetimi</strong>
            <span>Sistem kullanıcıları</span>
          </div>
        </a>
      </div>
    </div>
  </div>

</div>
