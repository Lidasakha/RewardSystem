@{
    ViewData["Title"] = "Ana Sayfa";
    ViewData["Active"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value?.ToLower();
    bool isTeacher   = rol == "teacher" || rol == "admin";
    bool isSuperAdmin= rol == "superadmin";
}

<style>
.adm-dash { display:flex;flex-direction:column;gap:20px; }

/* Banner */
.adm-banner {
  background:linear-gradient(135deg,#111827 0%,#1a2b4c 100%);
  border-radius:var(--radius-lg);padding:26px 30px;color:#fff;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
  position:relative;overflow:hidden;
}
.adm-banner::before{content:'';position:absolute;top:-50px;right:-50px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.04);}
.adm-banner h2{font-size:20px;font-weight:700;margin-bottom:4px;}
.adm-banner p {font-size:13px;color:rgba(255,255,255,.6);}
.adm-banner-actions{display:flex;gap:10px;flex-shrink:0;z-index:1;}
.adm-btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;transition:all .18s;text-decoration:none;border:none;}
.adm-btn-primary{background:#fff;color:#111827;}
.adm-btn-primary:hover{background:var(--accent);color:#fff;}
.adm-btn-secondary{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);}
.adm-btn-secondary:hover{background:rgba(255,255,255,.2);}

/* KPI */
.kpi-row{display:grid;gap:14px;}
.kpi-row-4{grid-template-columns:repeat(4,1fr);}
.kpi-row-3{grid-template-columns:repeat(3,1fr);}
@@media(max-width:1000px){.kpi-row-4,.kpi-row-3{grid-template-columns:repeat(2,1fr);}}
@@media(max-width:600px){.kpi-row-4,.kpi-row-3{grid-template-columns:1fr 1fr;}}
.kpi-c{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;display:flex;align-items:center;gap:14px;box-shadow:var(--shadow-sm);transition:box-shadow .2s,transform .2s;}
.kpi-c:hover{box-shadow:var(--shadow);transform:translateY(-2px);}
.kpi-ic{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.kpi-num{font-size:28px;font-weight:800;color:var(--text);line-height:1;}
.kpi-lbl{font-size:12px;color:var(--text-muted);margin-top:3px;}

/* Two col */
.two-col{display:grid;grid-template-columns:1.5fr 1fr;gap:20px;}
@@media(max-width:900px){.two-col{grid-template-columns:1fr;}}

/* Panel */
.adm-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;}
.adm-panel-head{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--border);font-weight:700;font-size:14px;color:var(--text);}
.see-all{font-size:12px;color:var(--accent);font-weight:600;text-decoration:none;}
.see-all:hover{opacity:.75;}

/* List */
.adm-li{display:flex;align-items:center;gap:12px;padding:13px 20px;border-bottom:1px solid var(--border);transition:background .15s;}
.adm-li:last-child{border-bottom:none;}
.adm-li:hover{background:var(--surface-2);}
.adm-li-ic{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.adm-li-title{font-size:13.5px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.adm-li-sub{font-size:11.5px;color:var(--text-muted);margin-top:2px;}

/* Quick actions */
.qa-list{display:flex;flex-direction:column;gap:8px;padding:14px;}
.qa-item{display:flex;align-items:center;gap:12px;padding:13px 14px;border-radius:var(--radius-sm);border:1px solid var(--border);text-decoration:none;transition:all .18s;}
.qa-item:hover{background:var(--surface-2);border-color:var(--gray-300);}
.qa-ic{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.qa-title{font-size:13.5px;font-weight:700;color:var(--text);}
.qa-sub{font-size:11.5px;color:var(--text-muted);}

.adm-empty{padding:32px 20px;text-align:center;color:var(--text-muted);font-size:13.5px;}
</style>

<div class="adm-dash">

  <!-- Banner -->
  <div class="adm-banner">
    <div>
      <h2>@(isSuperAdmin ? "Dekan Paneli" : "Öğretim Üyesi Paneli")</h2>
      <p>@(isSuperAdmin ? "Tüm bölümleri yönetin ve istatistikleri takip edin." : "Bölümünüzün çalışmalarını değerlendirin ve takip edin.")</p>
    </div>
    <div class="adm-banner-actions">
      @if (isSuperAdmin)
      {
        <a href="/Admin/OnayBekleyenOgrenciler" class="adm-btn adm-btn-primary">
          <i class="ti ti-user-check"></i> Öğrenci Onayla
        </a>
        <a href="/Admin/AdminYonetimi" class="adm-btn adm-btn-secondary">
          <i class="ti ti-settings-2"></i> Yönetim
        </a>
      }
      else
      {
        <a href="/Admin/Degerlendirmelerim" class="adm-btn adm-btn-primary">
          <i class="ti ti-clipboard-check"></i> Değerlendirmelerim
        </a>
        <a href="/Admin/BolumRaporlar" class="adm-btn adm-btn-secondary">
          <i class="ti ti-chart-bar"></i> Raporlar
        </a>
      }
    </div>
  </div>

  @if (isSuperAdmin)
  {
    <!-- Dekan KPI -->
    <div class="kpi-row kpi-row-3">
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-file-time"></i></div>
        <div><div class="kpi-num">@ViewBag.PendingArticles</div><div class="kpi-lbl">Bekleyen Çalışma</div></div>
      </div>
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--blue-bg);color:var(--blue);"><i class="ti ti-user-question"></i></div>
        <div><div class="kpi-num">@ViewBag.PendingStudents</div><div class="kpi-lbl">Onay Bekleyen Öğrenci</div></div>
      </div>
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-users"></i></div>
        <div><div class="kpi-num">@ViewBag.TotalActiveStudents</div><div class="kpi-lbl">Aktif Öğrenci</div></div>
      </div>
    </div>

    <!-- Dekan Grid -->
    <div class="two-col">
      <div class="adm-panel">
        <div class="adm-panel-head">
          <span><i class="ti ti-file-time" style="color:var(--yellow);margin-right:6px;"></i>Son Bekleyen Çalışmalar</span>
          <a href="/Admin/AdminYonetimi" class="see-all">Tümünü Yönet →</a>
        </div>
        @if (ViewBag.RecentPendingArticles == null || !((List<RewardSystem.Models.Article>)ViewBag.RecentPendingArticles).Any())
        {
          <div class="adm-empty"><i class="ti ti-checks" style="font-size:32px;color:var(--green);display:block;margin-bottom:8px;"></i>Bekleyen çalışma yok.</div>
        }
        else
        {
          @foreach (var a in (List<RewardSystem.Models.Article>)ViewBag.RecentPendingArticles)
          {
            <div class="adm-li">
              <div class="adm-li-ic" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-file-text"></i></div>
              <div style="flex:1;min-width:0;">
                <div class="adm-li-title">@a.Title</div>
                <div class="adm-li-sub">@a.User?.FullName · @(a.Year ?? 0)</div>
              </div>
              <span style="font-size:10.5px;font-weight:700;padding:3px 10px;border-radius:20px;background:var(--yellow-bg);color:var(--yellow);">Bekliyor</span>
            </div>
          }
        }
      </div>
      <div class="adm-panel">
        <div class="adm-panel-head"><span>Hızlı İşlemler</span></div>
        <div class="qa-list">
          <a href="/Admin/OnayBekleyenOgrenciler" class="qa-item">
            <div class="qa-ic" style="background:var(--blue-bg);color:var(--blue);"><i class="ti ti-user-check"></i></div>
            <div><div class="qa-title">Öğrenci Onayları</div><div class="qa-sub">Kayıt bekleyenleri onayla</div></div>
          </a>
          <a href="/Admin/AdminYonetimi" class="qa-item">
            <div class="qa-ic" style="background:var(--purple-bg);color:var(--purple);"><i class="ti ti-clipboard-check"></i></div>
            <div><div class="qa-title">Akademik Yönetim</div><div class="qa-sub">Hoca ata, süreci başlat</div></div>
          </a>
          <a href="/Admin/Raporlar" class="qa-item">
            <div class="qa-ic" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-chart-bar"></i></div>
            <div><div class="qa-title">Raporlar & İstatistikler</div><div class="qa-sub">Tüm üniversite verileri</div></div>
          </a>
          <a href="/Admin/KullaniciYonetimi" class="qa-item">
            <div class="qa-ic" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-settings-2"></i></div>
            <div><div class="qa-title">Kullanıcı Yönetimi</div><div class="qa-sub">Admin ve hocaları yönet</div></div>
          </a>
        </div>
      </div>
    </div>
  }
  else
  {
    <!-- Öğretmen KPI -->
    <div class="kpi-row kpi-row-3">
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-circle-check"></i></div>
        <div><div class="kpi-num">@(ViewBag.BenimDegerlendirme ?? 0)</div><div class="kpi-lbl">Değerlendirdiğim</div></div>
      </div>
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--yellow-bg);color:var(--yellow);"><i class="ti ti-clock"></i></div>
        <div><div class="kpi-num">@(ViewBag.BekleyenDegerlendirme ?? 0)</div><div class="kpi-lbl">Bekleyen</div></div>
      </div>
      <div class="kpi-c">
        <div class="kpi-ic" style="background:var(--purple-bg);color:var(--purple);"><i class="ti ti-star"></i></div>
        <div><div class="kpi-num">@(Math.Round((double)(ViewBag.OrtPuan ?? 0.0), 1))</div><div class="kpi-lbl">Ort. Verilen Puan</div></div>
      </div>
    </div>

    <!-- Öğretmen Grid -->
    <div class="two-col">
      <div class="adm-panel">
        <div class="adm-panel-head">
          <span><i class="ti ti-clipboard-check" style="color:var(--green);margin-right:6px;"></i>Son Değerlendirmelerim</span>
          <a href="/Admin/Degerlendirmelerim" class="see-all">Tümünü Gör →</a>
        </div>
        @{
          var sonDeger = ViewBag.SonDegerlendirmeler as IEnumerable<RewardSystem.Models.ArticleTeacherAssignment>;
        }
        @if (sonDeger == null || !sonDeger.Any())
        {
          <div class="adm-empty"><i class="ti ti-clipboard" style="font-size:32px;opacity:.3;display:block;margin-bottom:8px;"></i>Henüz değerlendirme yapılmadı.</div>
        }
        else
        {
          @foreach (var d in sonDeger)
          {
            <div class="adm-li">
              <div class="adm-li-ic" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-file-check"></i></div>
              <div style="flex:1;min-width:0;">
                <div class="adm-li-title">@d.Article?.Title</div>
                <div class="adm-li-sub">@d.Article?.User?.FullName</div>
              </div>
              <span style="font-size:13px;font-weight:800;color:var(--green);">@d.GivenScore p</span>
            </div>
          }
        }
      </div>

      <div class="adm-panel">
        <div class="adm-panel-head"><span>Hızlı İşlemler</span></div>
        <div class="qa-list">
          <a href="/Admin/Degerlendirmelerim" class="qa-item">
            <div class="qa-ic" style="background:var(--blue-bg);color:var(--blue);"><i class="ti ti-clipboard-check"></i></div>
            <div><div class="qa-title">Değerlendirmelerim</div><div class="qa-sub">Atanan çalışmaları değerlendir</div></div>
          </a>
          <a href="/Admin/Ogrenciler" class="qa-item">
            <div class="qa-ic" style="background:var(--green-bg);color:var(--green);"><i class="ti ti-users"></i></div>
            <div><div class="qa-title">Öğrenci Listesi</div><div class="qa-sub">Tüm öğrencileri gör</div></div>
          </a>
          <a href="/Admin/BolumRaporlar" class="qa-item">
            <div class="qa-ic" style="background:var(--purple-bg);color:var(--purple);"><i class="ti ti-chart-bar"></i></div>
            <div><div class="qa-title">Bölüm Raporları</div><div class="qa-sub">İstatistik & grafikler</div></div>
          </a>
        </div>
      </div>
    </div>
  }

</div>
