@model List<RewardSystem.Models.User>
@{
    ViewData["Title"] = "Kullanıcı Yönetimi";
    ViewData["Active"] = "KullaniciYonetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="panel">
    <div class="panel-head">
        <span>Admin & Yetkili Yönetimi</span>
        <button class="btn-primary" onclick="toggleAddForm()">+ Yeni Yetkili Ekle</button>
    </div>

    @if (TempData["Hata"] != null) { <div class="alert alert-danger">@TempData["Hata"]</div> }
    @if (TempData["Mesaj"] != null) { <div class="alert alert-success" style="background:#F0F4F8; color:#001F3F; border:1px solid #E3F2FD;">@TempData["Mesaj"]</div> }

    <!-- Edit Modal -->
    <div id="editModalOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:9999;align-items:center;justify-content:center;padding:20px;" onclick="if(event.target===this)closeEditForm()">
      <div style="background:var(--surface);border-radius:18px;width:100%;max-width:580px;box-shadow:0 20px 60px rgba(0,0,0,.2);overflow:hidden;">
        <div style="display:flex;align-items:center;justify-content:space-between;padding:18px 24px;border-bottom:1px solid var(--border);background:var(--surface-2);">
          <div style="font-size:16px;font-weight:800;color:var(--text);">Yetkili Düzenle</div>
          <button onclick="closeEditForm()" style="background:var(--gray-100);border:none;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:18px;color:var(--text-muted);display:flex;align-items:center;justify-content:center;">×</button>
        </div>
        <div style="padding:24px;">
          <form asp-action="KullaniciDuzenle" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="editUserId" />
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
              <div class="fg">
                <label>Ad Soyad</label>
                <input type="text" name="FullName" id="editFullName" class="form-input" required />
              </div>
              <div class="fg">
                <label>Kullanıcı Adı</label>
                <input type="text" name="Username" id="editUsername" class="form-input" required />
              </div>
              <div class="fg">
                <label>E-posta</label>
                <input type="email" name="Email" id="editEmail" class="form-input" required />
              </div>
              <div class="fg">
                <label>Rol</label>
                <select name="Role" id="editRole" class="form-input" required>
                  <option value="admin">Yönetici (Admin)</option>
                  <option value="superadmin">Süper Admin</option>
                  <option value="teacher">Öğretim Üyesi</option>
                </select>
              </div>
              <div class="fg">
                <label>Şifre (Boş bırakın = değişmez)</label>
                <div style="position:relative;">
                  <input type="password" name="rawPassword" id="editPassInput" class="form-input" placeholder="••••••••" style="padding-right:44px;" />
                  <i class="ti ti-eye" onclick="togglePass('editPassInput',this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#94a3b8;font-size:18px;"></i>
                </div>
              </div>
              <div class="fg">
                <label>Bölüm / Ünvan</label>
                <input type="text" name="Department" id="editDepartment" class="form-input" />
              </div>
            </div>
            <div style="margin-top:20px;display:flex;gap:10px;justify-content:flex-end;">
              <button type="button" onclick="closeEditForm()" style="padding:10px 20px;background:var(--gray-100);border:none;border-radius:8px;cursor:pointer;font-family:'Sora',sans-serif;font-weight:600;color:var(--text);">Vazgeç</button>
              <button type="submit" style="padding:10px 24px;background:#1a2b4c;color:#fff;border:none;border-radius:8px;cursor:pointer;font-family:'Sora',sans-serif;font-weight:700;">Güncelle</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <!-- Add Form (Hidden by default) -->
    <div id="addUserForm" class="add-form" style="display:none; margin-bottom:25px; padding:20px; background:#F0F4F8; border-radius:15px; border:1px solid #E3F2FD;">
        <h3 style="margin-bottom:15px; color:#001F3F;">Yeni Yetkili Tanımla</h3>
        <form asp-action="KullaniciEkle" method="post">
            @Html.AntiForgeryToken()
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <div class="fg">
                    <label>Ad Soyad</label>
                    <input type="text" name="FullName" class="form-input" required placeholder="" />
                </div>
                <div class="fg">
                    <label>Kullanıcı Adı</label>
                    <input type="text" name="Username" class="form-input" required placeholder="" />
                </div>
                <div class="fg">
                    <label>E-posta</label>
                    <input type="email" name="Email" class="form-input" required placeholder="" />
                </div>
                <div class="fg">
                    <label>Rol</label>
                    <select name="Role" class="form-input" required>
                        <option value="admin">Yönetici (Admin)</option>
                        <option value="superadmin">Süper Admin</option>
                    </select>
                </div>
                <div class="fg">
                    <label>Şifre</label>
                    <div style="position:relative;">
                        <input type="password" name="rawPassword" id="addPassInput" class="form-input" required placeholder="••••••••" style="padding-right:44px;" />
                        <i class="ti ti-eye" onclick="togglePass('addPassInput', this)" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#94a3b8;font-size:18px;"></i>
                    </div>
                </div>
                <div class="fg">
                    <label>Bölüm / Ünvan</label>
                    <input type="text" name="Department" class="form-input" placeholder="" />
                </div>
            </div>
            <div style="margin-top:20px; display:flex; gap:10px;">
                <button type="submit" class="btn-primary">Kaydet</button>
                <button type="button" class="btn-secondary" onclick="toggleAddForm()">Vazgeç</button>
            </div>
        </form>
    </div>

    <!-- Search & Filter Bar -->
    <div class="pnd-toolbar" style="margin-bottom: 20px; display: flex; gap: 12px; align-items: center;">
        <div class="pnd-search-box" style="flex: 1; display: flex; align-items: center; background: #fff; border: 1.5px solid #E3F2FD; border-radius: 12px; padding: 0 15px; transition: all 0.2s;">
            <input type="text" id="userSearchInput" placeholder="İsim, kullanıcı adı veya e-posta ile ara..." oninput="filterUsers()" style="width: 100%; border: none; outline: none; padding: 12px 0; font-size: 13.5px; font-family: inherit; background: transparent;">
        </div>
        <div class="pnd-filter-box">
            <select id="roleFilter" onchange="filterUsers()" style="padding: 12px 15px; border: 1.5px solid #E3F2FD; border-radius: 12px; outline: none; font-size: 13.5px; background: #fff; color: #001F3F; font-weight: 600; font-family: inherit; cursor: pointer;">
                <option value="all">Tüm Roller</option>
                <option value="admin">Admin</option>
                <option value="superadmin">Süper Admin</option>
            </select>
        </div>
    </div>

    <div style="overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch;">
        <table class="table" style="width: 100%; table-layout: fixed;">
            <thead>
                <tr>
                    <th style="width: 30%;">Ad Soyad</th>
                    <th style="width: 35%;">E-posta</th>
                    <th style="width: 15%;">Durum</th>
                    <th style="width: 20%; text-align: right;">İşlemler</th>
                </tr>
            </thead>
            <tbody id="userTableBody">
                @foreach(var u in Model) {
                    <tr class="kullanici-satir @(!u.IsActive ? "row-pasif" : "")" data-id="@u.Id" data-fullname="@u.FullName" data-username="@u.Username" data-email="@u.Email" data-department="@u.Department" data-role="@u.Role.ToLower()" data-search="@u.FullName.ToLower() @u.Username.ToLower() @u.Email.ToLower() @u.Department?.ToLower()">
                        <td style="white-space: nowrap;"><strong style="@(!u.IsActive ? "opacity:.5;" : "")">@u.FullName</strong></td>
                        <td style="word-break: break-all; @(!u.IsActive ? "opacity:.5;" : "")">@u.Email</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span style="display:inline-flex;align-items:center;gap:5px;background:var(--green-bg);color:var(--green);padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;">
                                    <span style="width:5px;height:5px;border-radius:50%;background:currentColor;display:inline-block;"></span> Aktif
                                </span>
                            }
                            else
                            {
                                <span style="display:inline-flex;align-items:center;gap:5px;background:var(--gray-100);color:var(--text-muted);padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;">
                                    <span style="width:5px;height:5px;border-radius:50%;background:currentColor;display:inline-block;"></span> Pasif
                                </span>
                            }
                        </td>
                        <td style="text-align: right; white-space: nowrap;">
                            <button class="btn-action" style="background:#f1f5f9; color:#1a2b4c; border:1px solid #cbd5e1;" onclick="openEditForm(this)">Düzenle</button>
                            <form asp-action="KullaniciDurumDegistir" method="post" style="display:inline;">
                              @Html.AntiForgeryToken()
                              <input type="hidden" name="id" value="@u.Id" />
                              @if (u.IsActive)
                              {
                                <button type="button" class="btn-action btn-reject"
                                    onclick="confirmPasif(this, '@u.FullName')">
                                    Pasifleştir
                                </button>
                              }
                              else
                              {
                                <button type="button" class="btn-action"
                                    style="background:var(--green);color:#fff;border:none;"
                                    onclick="confirmAktif(this, '@u.FullName')">
                                    Aktifleştir
                                </button>
                              }
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div id="noUsersFound" style="display:none; text-align:center; padding:40px; color:#888; font-size:14px;">Eşleşen kullanıcı bulunamadı.</div>
</div>

<style>
    .alert { padding:12px; border-radius:10px; margin-bottom:15px; font-size:14px; }
    .alert-danger { background:#fee; color:#c00; border:1px solid #fcc; }
    .alert-success { background:#eef6f1; color:#1a4731; border:1px solid #ddeee5; }
    
    .table { width:100%; border-collapse:collapse; }
    .table th, .table td { padding:15px; text-align:left; border-bottom:1px solid #eee; font-size:14px; }
    .table th { color:#888; font-weight:600; text-transform:uppercase; font-size:12px; letter-spacing:0.5px; }
    
    .fg label { display:block; font-size:13px; font-weight:600; color:#001F3F; margin-bottom:5px; }
    .form-input { width:100%; padding:10px; border:1.5px solid #ddeee5; border-radius:8px; outline:none; font-family:inherit; }
    .form-input:focus { border-color:#001F3F; }

    .badge { padding:4px 8px; border-radius:6px; font-size:11px; font-weight:700; text-transform:uppercase; }
    .badge-super { background:#fff0c2; color:#856404; }
    .badge-admin { background:#e2e3e5; color:#383d41; }
    .badge-teacher { background:#d1ecf1; color:#0c5460; }
    
    .status-active { color:#28a745; font-weight:600; font-size:12px; }
    .row-pasif { opacity:.75; background: var(--surface-2); }
    
    .btn-secondary { background:#eee; color:#333; border:none; padding:10px 20px; border-radius:8px; cursor:pointer; font-weight:600; }
</style>

<script>
    // Mesaj varsa formları kapat
    document.addEventListener('DOMContentLoaded', function() {
        @if (TempData["Mesaj"] != null || TempData["Hata"] != null || TempData["DebugMessage"] != null)
        {
            @Html.Raw("document.getElementById('editModalOverlay').style.display = 'none';")
            @Html.Raw("document.getElementById('addUserForm').style.display = 'none';")
        }
    });

    function togglePass(inputId, icon) {
        var input = document.getElementById(inputId);
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('ti-eye');
            icon.classList.add('ti-eye-off');
        } else {
            input.type = 'password';
            icon.classList.remove('ti-eye-off');
            icon.classList.add('ti-eye');
        }
    }

    function toggleAddForm() {
        var form = document.getElementById('addUserForm');
        form.style.display = form.style.display === 'none' ? 'block' : 'none';
        document.getElementById('editModalOverlay').style.display = 'none';
    }

    function openEditForm(btn) {
        var tr = btn.closest('tr');
        document.getElementById('editUserId').value    = tr.getAttribute('data-id');
        document.getElementById('editFullName').value  = tr.getAttribute('data-fullname');
        document.getElementById('editUsername').value  = tr.getAttribute('data-username');
        document.getElementById('editEmail').value     = tr.getAttribute('data-email');
        document.getElementById('editRole').value      = tr.getAttribute('data-role');
        document.getElementById('editDepartment').value= tr.getAttribute('data-department') || '';
        document.getElementById('editPassInput').value = '';

        document.getElementById('addUserForm').style.display = 'none';
        var ov = document.getElementById('editModalOverlay');
        ov.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeEditForm() {
        document.getElementById('editModalOverlay').style.display = 'none';
        document.body.style.overflow = '';
    }

    function filterUsers() {
        const query = document.getElementById('userSearchInput').value.toLowerCase().trim();
        const roleFilterValue = document.getElementById('roleFilter').value.toLowerCase();
        const rows = document.querySelectorAll('.kullanici-satir');
        const noResults = document.getElementById('noUsersFound');
        const table = document.querySelector('.table');
        let visibleCount = 0;

        rows.forEach(row => {
            const searchData = row.getAttribute('data-search') || '';
            const role = row.getAttribute('data-role') || '';
            
            const matchesSearch = searchData.includes(query);
            const matchesRole = roleFilterValue === 'all' || role === roleFilterValue;

            if (matchesSearch && matchesRole) {
                row.style.display = 'table-row';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });

        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        table.style.display = visibleCount === 0 ? 'none' : '';
    }
    function confirmPasif(button, userName) {
        Swal.fire({
            title: 'Pasifleştirmek istiyor musunuz?',
            text: userName + " adlı üye pasifleştirilecek ve sisteme giriş yapamayacak.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc2626',
            cancelButtonColor: '#1a2b4c',
            confirmButtonText: 'Evet, Pasifleştir',
            cancelButtonText: 'Vazgeç',
            background: document.body.classList.contains('dark-mode') ? '#0f172a' : '#fff',
            color: document.body.classList.contains('dark-mode') ? '#e2e8f0' : '#0f172a'
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Son onay',
                    text: 'Bu işlemi geri almak için tekrar "Aktifleştir" butonuna basmanız gerekecek.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc2626',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Onaylıyorum, Pasifleştir',
                    cancelButtonText: 'Vazgeç',
                    background: document.body.classList.contains('dark-mode') ? '#0f172a' : '#fff',
                    color: document.body.classList.contains('dark-mode') ? '#e2e8f0' : '#0f172a'
                }).then((result2) => {
                    if (result2.isConfirmed) {
                        button.closest('form').submit();
                    }
                });
            }
        });
    }

    function confirmAktif(button, userName) {
        Swal.fire({
            title: 'Aktifleştirmek istiyor musunuz?',
            text: userName + " adlı üye aktifleştirilecek ve sisteme giriş yapabilecek.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#16a34a',
            cancelButtonColor: '#1a2b4c',
            confirmButtonText: 'Evet, Aktifleştir',
            cancelButtonText: 'Vazgeç',
            background: document.body.classList.contains('dark-mode') ? '#0f172a' : '#fff',
            color: document.body.classList.contains('dark-mode') ? '#e2e8f0' : '#0f172a'
        }).then((result) => {
            if (result.isConfirmed) {
                button.closest('form').submit();
            }
        });
    }
    // Input odaklanma stilleri
    document.styleSheets[0].insertRule('.pnd-search-box:focus-within { border-color: #001F3F !important; box-shadow: 0 0 0 3px rgba(0, 31, 63, 0.1); }', 0);
    document.addEventListener('keydown', function(e) { if(e.key==='Escape') closeEditForm(); });
    document.styleSheets[0].insertRule('#roleFilter:focus { border-color: #001F3F !important; box-shadow: 0 0 0 3px rgba(0, 31, 63, 0.1); }', 0);
</script>
