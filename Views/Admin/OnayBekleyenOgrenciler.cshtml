@model List<RewardSystem.Models.User>
@{
    ViewData["Title"] = "Öğrenci Yönetimi";
    ViewData["Active"] = "OnayBekleyenOgrenciler";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var aktifOgrenciler = ViewBag.AktifOgrenciler as List<RewardSystem.Models.User> ?? new();
    var tumOgrenciler = Model.Concat(aktifOgrenciler).ToList();
}

<style>
.og-page { display:flex;flex-direction:column;gap:20px; }

/* Banner */
.og-banner {
  background:linear-gradient(135deg,#111827 0%,#1a2b4c 100%);
  border-radius:var(--radius-lg);padding:24px 28px;color:#fff;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
  position:relative;overflow:hidden;
}
.og-banner::before{content:'';position:absolute;top:-50px;right:-50px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.05);}
.og-banner-left{display:flex;align-items:center;gap:16px;z-index:1;}
.og-banner-icon{width:52px;height:52px;border-radius:14px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;}
.og-banner-left h2{font-size:19px;font-weight:700;margin-bottom:3px;}
.og-banner-left p{font-size:13px;color:rgba(255,255,255,.65);}
.og-banner-stats{display:flex;gap:12px;z-index:1;}
.og-stat{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.18);border-radius:14px;padding:12px 20px;text-align:center;}
.og-stat-num{font-size:24px;font-weight:800;line-height:1;}
.og-stat-lbl{font-size:10px;color:rgba(255,255,255,.6);margin-top:3px;text-transform:uppercase;letter-spacing:.4px;}

/* Alerts */
.og-alert{display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:var(--radius-sm);font-size:13.5px;font-weight:600;}
.og-alert-success{background:var(--green-bg);border:1px solid rgba(22,163,74,.25);color:var(--green);}
.og-alert-danger{background:var(--red-bg);border:1px solid rgba(220,38,38,.25);color:var(--red);}
.og-alert-x{margin-left:auto;background:none;border:none;cursor:pointer;color:inherit;opacity:.6;font-size:18px;}

/* Toolbar */
.og-toolbar{display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:12px 16px;box-shadow:var(--shadow-sm);}
.og-search{flex:1;display:flex;align-items:center;gap:10px;background:var(--surface-2);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:0 14px;transition:border-color .18s;}
.og-search:focus-within{border-color:var(--border-focus);box-shadow:0 0 0 3px rgba(74,112,196,.1);}
.og-search i{font-size:17px;color:var(--text-muted);}
.og-search input{flex:1;border:none;outline:none;padding:10px 0;font-family:'Sora',sans-serif;font-size:13.5px;color:var(--text);background:transparent;}
.og-search input::placeholder{color:var(--text-light);}
.og-sel{padding:10px 14px;background:var(--surface-2);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:'Sora',sans-serif;font-size:13px;color:var(--text);outline:none;cursor:pointer;}

/* Table */
.og-table-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow-sm);}
.og-table{width:100%;border-collapse:separate;border-spacing:0;}
.og-table th{text-align:left;padding:13px 20px;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;border-bottom:2px solid var(--border);background:var(--surface-2);white-space:nowrap;}
.og-table td{padding:13px 20px;font-size:13.5px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:middle;}
.og-table tbody tr:last-child td{border-bottom:none;}
.og-table tbody tr{transition:background .15s;}
.og-table tbody tr:hover{background:var(--surface-2);}

.og-user{display:flex;align-items:center;gap:12px;}
.og-av{width:40px;height:40px;border-radius:11px;color:#fff;font-weight:800;font-size:15px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.og-name{font-weight:700;font-size:13.5px;color:var(--text);}
.og-uname{font-size:11.5px;color:var(--text-muted);margin-top:1px;}

.og-badge-bekl{display:inline-flex;align-items:center;gap:5px;background:var(--yellow-bg);color:var(--yellow);border:1px solid rgba(217,119,6,.2);padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;}
.og-badge-aktif{display:inline-flex;align-items:center;gap:5px;background:var(--green-bg);color:var(--green);border:1px solid rgba(22,163,74,.2);padding:4px 11px;border-radius:20px;font-size:11px;font-weight:700;}
.og-pulse{width:6px;height:6px;border-radius:50%;background:var(--yellow);animation:ogPulse 2s ease-in-out infinite;}
@@keyframes ogPulse{0%,100%{opacity:1}50%{opacity:.4}}

.og-actions{display:flex;gap:8px;}
.og-btn-ok{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border:none;border-radius:var(--radius-sm);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;background:var(--green);color:#fff;transition:all .15s;}
.og-btn-ok:hover{opacity:.85;}
.og-btn-red{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border:1px solid rgba(220,38,38,.25);border-radius:var(--radius-sm);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;background:var(--red-bg);color:var(--red);transition:all .15s;}
.og-btn-red:hover{background:var(--red);color:#fff;border-color:transparent;}

.og-empty{padding:50px 20px;text-align:center;color:var(--text-muted);}
.og-empty i{font-size:44px;display:block;margin-bottom:14px;opacity:.2;}
</style>

<div class="og-page">

  @if (TempData["Mesaj"] != null)
  {
    <div class="og-alert og-alert-success">
      <i class="ti ti-circle-check" style="font-size:20px;"></i>
      <span>@TempData["Mesaj"]</span>
      <button class="og-alert-x" onclick="this.parentElement.remove()">×</button>
    </div>
  }
  @if (TempData["Hata"] != null)
  {
    <div class="og-alert og-alert-danger">
      <i class="ti ti-alert-circle" style="font-size:20px;"></i>
      <span>@TempData["Hata"]</span>
      <button class="og-alert-x" onclick="this.parentElement.remove()">×</button>
    </div>
  }

  <!-- Banner -->
  <div class="og-banner">
    <div class="og-banner-left">
      <div class="og-banner-icon"><i class="ti ti-users"></i></div>
      <div>
        <h2>Öğrenci Yönetimi</h2>
        <p>Tüm öğrencileri yönetin, onaylayın veya reddedin.</p>
      </div>
    </div>
    <div class="og-banner-stats">
      <div class="og-stat">
        <div class="og-stat-num" style="color:#fbbf24;">@Model.Count</div>
        <div class="og-stat-lbl">Bekleyen</div>
      </div>
      <div class="og-stat">
        <div class="og-stat-num" style="color:#34d399;">@aktifOgrenciler.Count</div>
        <div class="og-stat-lbl">Aktif</div>
      </div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="og-toolbar">
    <div class="og-search">
      <i class="ti ti-search"></i>
      <input type="text" id="ogSearch" placeholder="İsim, e-posta veya bölüm ile ara..." oninput="filterOg(this.value)">
    </div>
    <select class="og-sel" id="ogDurumSel" onchange="filterOg(document.getElementById('ogSearch').value)">
      <option value="">Tüm Durumlar (@tumOgrenciler.Count)</option>
      <option value="bekliyor">Bekleyen (@Model.Count)</option>
      <option value="aktif">Aktif (@aktifOgrenciler.Count)</option>
    </select>
  </div>

  <!-- Tek Tablo -->
  <div class="og-table-wrap">
    @if (!tumOgrenciler.Any())
    {
      <div class="og-empty">
        <i class="ti ti-users"></i>
        <p>Henüz kayıtlı öğrenci yok.</p>
      </div>
    }
    else
    {
      <div style="overflow-x:auto;">
        <table class="og-table" id="ogTable">
          <thead>
            <tr>
              <th>Öğrenci</th>
              <th>E-posta</th>
              <th>Bölüm</th>
              <th>Sınıf</th>
              <th>Kayıt Tarihi</th>
              <th>Durum</th>
              <th>İşlem</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var s in Model)
            {
              <tr data-name="@s.FullName?.ToLower()" data-email="@s.Email?.ToLower()" data-dept="@s.Department?.ToLower()" data-durum="bekliyor">
                <td>
                  <div class="og-user">
                    <div class="og-av" style="background:#f59e0b;">@(s.FullName?.Length > 0 ? s.FullName[0].ToString().ToUpper() : "?")</div>
                    <div>
                      <div class="og-name">@s.FullName</div>
                      <div class="og-uname">@s.Username</div>
                    </div>
                  </div>
                </td>
                <td>@(s.Email ?? "—")</td>
                <td>@(s.Department ?? "—")</td>
                <td>@(s.Grade ?? "—")</td>
                <td>@(s.CreateDate == default(DateTime) ? "—" : s.CreateDate.ToLocalTime().ToString("dd MMM yyyy"))</td>
                <td>
                  <span class="og-badge-bekl"><span class="og-pulse"></span> Bekliyor</span>
                </td>
                <td>
                  <div class="og-actions">
                    <form asp-action="OgrenciOnayla" method="post" onsubmit="return confirm('Bu öğrenciyi onaylamak istiyor musunuz?');">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="id" value="@s.Id" />
                      <button type="submit" class="og-btn-ok"><i class="ti ti-check"></i> Onayla</button>
                    </form>
                    <form asp-action="OgrenciReddet" method="post" onsubmit="return confirm('@s.FullName adlı öğrenciyi reddetmek istiyor musunuz?');">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="id" value="@s.Id" />
                      <button type="submit" class="og-btn-red"><i class="ti ti-x"></i> Reddet</button>
                    </form>
                  </div>
                </td>
              </tr>
            }
            @foreach (var s in aktifOgrenciler)
            {
              <tr data-name="@s.FullName?.ToLower()" data-email="@s.Email?.ToLower()" data-dept="@s.Department?.ToLower()" data-durum="aktif">
                <td>
                  <div class="og-user">
                    <div class="og-av" style="background:var(--green);">@(s.FullName?.Length > 0 ? s.FullName[0].ToString().ToUpper() : "?")</div>
                    <div>
                      <div class="og-name">@s.FullName</div>
                      <div class="og-uname">@s.Username</div>
                    </div>
                  </div>
                </td>
                <td>@(s.Email ?? "—")</td>
                <td>@(s.Department ?? "—")</td>
                <td>@(s.Grade ?? "—")</td>
                <td>@(s.CreateDate == default(DateTime) ? "—" : s.CreateDate.ToLocalTime().ToString("dd MMM yyyy"))</td>
                <td>
                  <span class="og-badge-aktif"><i class="ti ti-circle-check" style="font-size:12px;"></i> Aktif</span>
                </td>
                <td>—</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>

</div>

<script>
function filterOg(query) {
  const q = query.toLowerCase().trim();
  const durum = document.getElementById('ogDurumSel').value;
  const rows = document.querySelectorAll('#ogTable tbody tr');
  rows.forEach(row => {
    const name  = row.getAttribute('data-name')  || '';
    const email = row.getAttribute('data-email') || '';
    const dept  = row.getAttribute('data-dept')  || '';
    const d     = row.getAttribute('data-durum') || '';
    const textMatch  = !q || name.includes(q) || email.includes(q) || dept.includes(q);
    const durumMatch = !durum || d === durum;
    row.style.display = textMatch && durumMatch ? '' : 'none';
  });
}
</script>
