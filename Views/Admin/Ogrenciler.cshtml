@model List<RewardSystem.Models.User>
@{
    ViewData["Title"] = "Öğrenciler";
    ViewData["Active"] = "Ogrenciler";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="panel">
    <div class="panel-head">
        <span>👥 Öğrenci Listesi</span>
        <span style="font-size:12px;color:#6c7a89">@Model.Count öğrenci</span>
    </div>

    @if (!Model.Any())
    {
        <p class="empty">Henüz öğrenci yok.</p>
    }
    else
    {
        <table class="rapor-tablo">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Öğrenci</th>
                    <th>E-posta</th>
                    <th>Bölüm</th>
                    <th>Sınıf</th>
                    <th>Durum</th>
                    
                </tr>
            </thead>
            <tbody>
                @foreach (var (o, i) in Model.Select((o, i) => (o, i)))
                {
                    <tr>
                        <td><span class="rank-no">@(i+1)</span></td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px">
                                <div class="avatar-sm">@o.FullName[0]</div>
                                <div>
                                    <div style="font-weight:600;font-size:13.5px">@o.FullName</div>
                                    <div style="font-size:11.5px;color:#6c7a89">@@o.Username</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:13px;color:#6c7a89">@(o.Email ?? "—")</td>
                        <td style="font-size:13px">@(o.Department ?? "—")</td>
                        <td style="font-size:13px">@(o.Grade != null ? o.Grade + ". Sınıf" : "—")</td>
                        <td><span class="badge-green">Aktif</span></td>
                       
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<style>
.rapor-tablo { width:100%; border-collapse:collapse; }
.rapor-tablo th { padding:12px 20px; text-align:left; font-size:12px; font-weight:700; color:#6c7a89; text-transform:uppercase; letter-spacing:.5px; border-bottom:1.5px solid #e2e8f0; background:#ffffff; }
.rapor-tablo td { padding:14px 20px; font-size:13.5px; color:#0a1128; border-bottom:1px solid #f8fafc; }
.rapor-tablo tr:last-child td { border-bottom:none; }
.rapor-tablo tr:hover td { background:#ffffff; }
</style>

