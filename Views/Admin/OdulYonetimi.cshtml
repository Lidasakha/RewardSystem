@model List<RewardSystem.Models.Reward>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Ödül Yönetimi";
    ViewData["Active"] = "OdulYonetimi";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var odulSayilari    = ViewBag.OdulSayilari as Dictionary<int, int> ?? new();
    var ogrenciler      = ViewBag.Ogrenciler as List<RewardSystem.Models.User> ?? new();
    var verilenRozetler = ViewBag.VerilenRozetler as List<RewardSystem.Models.Badge> ?? new();
}

<style>
.oy-page { display:flex;flex-direction:column;gap:24px; }

/* Banner */
.oy-banner {
  background:linear-gradient(135deg,#111827 0%,#1a2b4c 100%);
  border-radius:var(--radius-lg);padding:26px 32px;color:#fff;
  display:flex;align-items:center;justify-content:space-between;gap:20px;
  position:relative;overflow:hidden;
}
.oy-banner::before{content:'';position:absolute;top:-60px;right:-60px;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.04);}
.oy-banner-left h2{font-size:20px;font-weight:800;margin-bottom:5px;}
.oy-banner-left p{font-size:13px;color:rgba(255,255,255,.55);}
.oy-banner-stat{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:14px;padding:14px 22px;text-align:center;z-index:1;}
.oy-banner-num{font-size:28px;font-weight:800;color:#fbbf24;line-height:1;}
.oy-banner-lbl{font-size:10px;color:rgba(255,255,255,.5);margin-top:4px;text-transform:uppercase;letter-spacing:.5px;}

/* Alerts */
.oy-alert{display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:var(--radius-sm);font-size:13.5px;font-weight:600;}
.oy-alert-ok {background:var(--green-bg);border:1px solid rgba(22,163,74,.25);color:var(--green);}
.oy-alert-err{background:var(--red-bg);border:1px solid rgba(220,38,38,.25);color:var(--red);}
.oy-alert-x{margin-left:auto;background:none;border:none;cursor:pointer;color:inherit;opacity:.6;font-size:18px;}

/* Panel */
.oy-panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;}
.oy-panel-head{padding:16px 22px;border-bottom:1px solid var(--border);font-size:14px;font-weight:700;color:var(--text);background:var(--surface-2);display:flex;align-items:center;justify-content:space-between;}
.oy-panel-body{padding:22px;}

/* Form */
.oy-form-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;}
@@media(max-width:900px){.oy-form-grid{grid-template-columns:1fr 1fr;}}
@@media(max-width:500px){.oy-form-grid{grid-template-columns:1fr;}}
.oy-field label{display:block;font-size:11px;font-weight:700;color:var(--text-muted);margin-bottom:7px;text-transform:uppercase;letter-spacing:.04em;}
.oy-input{width:100%;padding:10px 14px;background:var(--surface-2);border:1.5px solid var(--border);border-radius:var(--radius-sm);font-family:'Sora',sans-serif;font-size:13.5px;color:var(--text);outline:none;transition:border-color .18s,box-shadow .18s;}
.oy-input:focus{border-color:var(--border-focus);box-shadow:0 0 0 3px rgba(74,112,196,.1);}
.oy-color-wrap{display:flex;align-items:center;gap:10px;}
.oy-color-dot{width:34px;height:34px;border-radius:9px;border:2px solid var(--border);flex-shrink:0;transition:background .2s;}

/* Icon grid */
.oy-icon-grid{display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;}
.oy-icon-btn{width:38px;height:38px;border:1.5px solid var(--border);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:all .15s;background:var(--surface-2);}
.oy-icon-btn:hover{border-color:var(--accent);background:rgba(74,112,196,.1);}
.oy-icon-btn.selected{border-color:var(--accent);background:var(--accent);color:#fff;}

/* Save button */
.oy-save-btn{display:inline-flex;align-items:center;gap:7px;padding:11px 24px;background:var(--brand-600);color:#fff;border:none;border-radius:var(--radius-sm);font-family:'Sora',sans-serif;font-size:13.5px;font-weight:700;cursor:pointer;transition:all .18s;box-shadow:0 3px 10px rgba(26,43,76,.2);margin-top:18px;}
.oy-save-btn:hover{background:var(--brand-700);transform:translateY(-1px);}

/* Reward cards */
.oy-card-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px;}
.oy-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-sm);overflow:hidden;transition:box-shadow .2s,transform .2s;}
.oy-card:hover{box-shadow:var(--shadow);transform:translateY(-3px);}
.oy-card.pasif{opacity:.55;}
.oy-card-top{padding:20px;display:flex;align-items:flex-start;gap:14px;}
.oy-card-icon{width:54px;height:54px;border-radius:15px;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0;box-shadow:0 4px 14px rgba(0,0,0,.12);}
.oy-card-name{font-size:15px;font-weight:800;color:var(--text);margin-bottom:3px;}
.oy-card-desc{font-size:12px;color:var(--text-muted);line-height:1.45;}
.oy-card-meta{padding:12px 20px;display:flex;align-items:center;justify-content:space-between;background:var(--surface-2);border-top:1px solid var(--border);}
.oy-puan-badge{display:inline-flex;align-items:center;gap:5px;background:var(--yellow-bg);color:var(--yellow);padding:4px 12px;border-radius:20px;font-size:11.5px;font-weight:700;}
.oy-kazanan{font-size:11.5px;color:var(--text-muted);display:flex;align-items:center;gap:5px;}
.oy-card-actions{padding:12px 20px;display:flex;gap:8px;border-top:1px solid var(--border);}
.oy-btn-pasif{flex:1;padding:9px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface-2);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;justify-content:center;gap:5px;color:var(--text-muted);}
.oy-btn-pasif:hover{background:var(--yellow-bg);color:var(--yellow);border-color:var(--yellow);}
.oy-btn-aktif{flex:1;padding:9px;border-radius:var(--radius-sm);border:1.5px solid rgba(22,163,74,.3);background:var(--green-bg);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;justify-content:center;gap:5px;color:var(--green);}
.oy-btn-aktif:hover{background:var(--green);color:#fff;}
.oy-btn-del{flex:1;padding:9px;border-radius:var(--radius-sm);border:1.5px solid rgba(220,38,38,.2);background:var(--red-bg);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;justify-content:center;gap:5px;color:var(--red);}
.oy-btn-del:hover{background:var(--red);color:#fff;border-color:transparent;}

/* Empty */
.oy-empty{padding:48px 20px;text-align:center;color:var(--text-muted);}
.oy-empty i{font-size:44px;display:block;margin-bottom:14px;opacity:.25;}
.oy-empty-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:5px;}

/* Table */
.oy-table{width:100%;border-collapse:separate;border-spacing:0;}
.oy-table th{text-align:left;padding:12px 20px;font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;border-bottom:2px solid var(--border);background:var(--surface-2);}
.oy-table td{padding:13px 20px;border-bottom:1px solid var(--border);font-size:13.5px;color:var(--text);vertical-align:middle;}
.oy-table tbody tr:last-child td{border-bottom:none;}
.oy-table tbody tr{transition:background .15s;}
.oy-table tbody tr:hover{background:var(--surface-2);}
.oy-badge-chip{display:inline-flex;align-items:center;gap:6px;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;}
.oy-geri-btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border:1.5px solid rgba(220,38,38,.2);border-radius:var(--radius-sm);background:var(--red-bg);color:var(--red);font-family:'Sora',sans-serif;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;}
.oy-geri-btn:hover{background:var(--red);color:#fff;border-color:transparent;}

/* Manuel form */
.oy-manuel-grid{display:grid;grid-template-columns:1fr 1fr auto;gap:14px;align-items:flex-end;}
@@media(max-width:700px){.oy-manuel-grid{grid-template-columns:1fr;}}
</style>

<div class="oy-page">

  @if (TempData["Mesaj"] != null)
  {
    <div class="oy-alert oy-alert-ok">
      <i class="ti ti-circle-check" style="font-size:20px;"></i>
      <span>@TempData["Mesaj"]</span>
      <button class="oy-alert-x" onclick="this.parentElement.remove()">×</button>
    </div>
  }
  @if (TempData["Hata"] != null)
  {
    <div class="oy-alert oy-alert-err">
      <i class="ti ti-alert-circle" style="font-size:20px;"></i>
      <span>@TempData["Hata"]</span>
      <button class="oy-alert-x" onclick="this.parentElement.remove()">×</button>
    </div>
  }



  <!-- Yeni Ödül Tanımla -->
  <div class="oy-panel">
    <div class="oy-panel-head">
      <span><i class="ti ti-plus-circle" style="color:var(--accent);margin-right:8px;"></i>Yeni Ödül Tanımla</span>
    </div>
    <div class="oy-panel-body">
      <form asp-action="OdulEkle" method="post">
        @Html.AntiForgeryToken()
        <div class="oy-form-grid">
          <div class="oy-field">
            <label>Ödül Adı *</label>
            <input type="text" name="Name" class="oy-input" placeholder="Altın Öğrenci" required>
          </div>
          <div class="oy-field">
            <label>Minimum Puan *</label>
            <input type="number" name="MinPoints" class="oy-input" placeholder="100" min="0" required>
          </div>
          <div class="oy-field">
            <label>Açıklama</label>
            <input type="text" name="Description" class="oy-input" placeholder="100 puana ulaşan öğrencilere verilir">
          </div>
          <div class="oy-field">
            <label>İkon Seç</label>
            <input type="hidden" name="Icon" id="selectedIcon" value="ti-trophy">
            <div class="oy-icon-grid">
              @foreach (var icon in new[]{"ti-trophy","ti-medal","ti-star","ti-award","ti-certificate","ti-crown","ti-diamond","ti-rocket","ti-flame","ti-bolt","ti-heart","ti-sparkles"})
              {
                <div class="oy-icon-btn @(icon == "ti-trophy" ? "selected" : "")" onclick="selectIcon('@icon', this)" title="@icon">
                  <i class="ti @icon"></i>
                </div>
              }
            </div>
          </div>
          <div class="oy-field">
            <label>Renk</label>
            <div class="oy-color-wrap">
              <div class="oy-color-dot" id="colorPreview" style="background:#f59e0b;"></div>
              <input type="color" name="Color" value="#f59e0b" class="oy-input" style="height:42px;padding:4px;cursor:pointer;"
                     onchange="document.getElementById('colorPreview').style.background=this.value">
            </div>
          </div>
        </div>
        <button type="submit" class="oy-save-btn">
          <i class="ti ti-device-floppy"></i> Ödülü Kaydet
        </button>
      </form>
    </div>
  </div>

  <!-- Manuel Ödül Ver -->
  <div class="oy-panel">
    <div class="oy-panel-head">
      <span><i class="ti ti-user-star" style="color:var(--accent);margin-right:8px;"></i>Manuel Ödül Ver</span>
      <span style="font-size:12px;color:var(--text-muted);">Öğrenciye doğrudan ödül ver</span>
    </div>
    <div class="oy-panel-body">
      @if (!Model.Any(r => r.IsActive))
      {
        <div class="oy-empty" style="padding:28px 20px;">
          <i class="ti ti-alert-circle" style="font-size:28px;margin-bottom:8px;"></i>
          <div style="font-size:13.5px;">Önce aktif bir ödül tanımlayın.</div>
        </div>
      }
      else
      {
        <form asp-action="ManuelOdulVer" method="post">
          @Html.AntiForgeryToken()
          <div class="oy-manuel-grid">
            <div class="oy-field">
              <label>Öğrenci Seç</label>
              <select name="userId" class="oy-input" required>
                <option value="">— Öğrenci seçin —</option>
                @foreach (var o in ogrenciler)
                {
                  <option value="@o.Id">@o.FullName @(!string.IsNullOrEmpty(o.Department) ? $"({o.Department})" : "")</option>
                }
              </select>
            </div>
            <div class="oy-field">
              <label>Ödül Seç</label>
              <select name="rewardId" class="oy-input" required>
                <option value="">— Ödül seçin —</option>
                @foreach (var r in Model.Where(r => r.IsActive))
                {
                  <option value="@r.Id">@r.Name (min. @r.MinPoints puan)</option>
                }
              </select>
            </div>
            <button type="submit" class="oy-save-btn" style="margin-top:0;">
              <i class="ti ti-gift"></i> Ver
            </button>
          </div>
        </form>
      }
    </div>
  </div>

  <!-- Verilen Rozetler -->
  <div class="oy-panel">
    <div class="oy-panel-head">
      <span><i class="ti ti-shield-check" style="color:var(--green);margin-right:8px;"></i>Verilen Rozetler</span>
      <span style="font-size:12px;color:var(--text-muted);">Son 50 kayıt</span>
    </div>
    @if (!verilenRozetler.Any())
    {
      <div class="oy-empty">
        <i class="ti ti-medal"></i>
        <div class="oy-empty-title">Henüz rozet verilmedi.</div>
      </div>
    }
    else
    {
      <div style="overflow-x:auto;">
        <table class="oy-table">
          <thead>
            <tr>
              <th>Öğrenci</th>
              <th>Rozet</th>
              <th>Verilme Tarihi</th>
              <th>İşlem</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var b in verilenRozetler)
            {
              var color = b.Color ?? "#f59e0b";
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:10px;">
                    <div style="width:36px;height:36px;border-radius:10px;background:var(--brand-600);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;flex-shrink:0;">
                      @(b.User?.FullName?.Length > 0 ? b.User.FullName[0].ToString().ToUpper() : "?")
                    </div>
                    <div>
                      <div style="font-weight:700;color:var(--text);font-size:13.5px;">@b.User?.FullName</div>
                      <div style="font-size:11.5px;color:var(--text-muted);">@(b.User?.Department ?? "—")</div>
                    </div>
                  </div>
                </td>
                <td>
                  <span class="oy-badge-chip" style="background:@color+1a;color:@color;">
                    <i class="ti @(b.Icon ?? "ti-trophy")"></i> @b.BadgeName
                  </span>
                </td>
                <td style="font-size:12.5px;color:var(--text-muted);">
                  @b.EarnedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
                </td>
                <td>
                  <form asp-action="OdulGeriAl" method="post" style="display:inline;"
                        onsubmit="return confirm('@(b.User?.FullName) adlı öğrencinin @b.BadgeName rozetini geri almak istiyor musunuz?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="badgeId" value="@b.Id">
                    <button type="submit" class="oy-geri-btn">
                      <i class="ti ti-x"></i> Geri Al
                    </button>
                  </form>
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>

  <!-- Ödül Listesi -->
  <div class="oy-panel">
    <div class="oy-panel-head">
      <span><i class="ti ti-trophy" style="color:#f59e0b;margin-right:8px;"></i>Tanımlı Ödüller</span>
      <span style="font-size:12px;color:var(--text-muted);">@Model.Count ödül</span>
    </div>
    @if (!Model.Any())
    {
      <div class="oy-empty">
        <i class="ti ti-trophy"></i>
        <div class="oy-empty-title">Henüz ödül tanımlanmadı.</div>
        <div style="font-size:13px;">Yukarıdaki formu kullanarak ilk ödülü ekleyin.</div>
      </div>
    }
    else
    {
      <div style="padding:20px;">
        <div class="oy-card-grid">
          @foreach (var o in Model)
          {
            var kazananSayi = odulSayilari.GetValueOrDefault(o.Id, 0);
            var color = o.Color ?? "#f59e0b";
            <div class="oy-card @(!o.IsActive ? "pasif" : "")" style="border-top:3px solid @color;">
              <div class="oy-card-top">
                <div class="oy-card-icon" style="background:@color+1a;color:@color;">
                  <i class="ti @(o.Icon ?? "ti-trophy")"></i>
                </div>
                <div style="flex:1;min-width:0;">
                  <div class="oy-card-name">@o.Name</div>
                  <div class="oy-card-desc">@(o.Description ?? "Açıklama yok")</div>
                </div>
                @if (!o.IsActive)
                {
                  <span style="background:var(--gray-100);color:var(--text-muted);padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;white-space:nowrap;">Pasif</span>
                }
              </div>
              <div class="oy-card-meta">
                <span class="oy-puan-badge"><i class="ti ti-star" style="font-size:12px;"></i> Min. @o.MinPoints puan</span>
                <span class="oy-kazanan"><i class="ti ti-users" style="font-size:13px;"></i> @kazananSayi kazandı</span>
              </div>
              <div class="oy-card-actions">
                <form asp-action="OdulDurumDegistir" method="post" style="flex:1;display:contents;">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@o.Id">
                  @if (o.IsActive)
                  {
                    <button type="submit" class="oy-btn-pasif">
                      <i class="ti ti-eye-off"></i> Pasifleştir
                    </button>
                  }
                  else
                  {
                    <button type="submit" class="oy-btn-aktif">
                      <i class="ti ti-eye"></i> Aktifleştir
                    </button>
                  }
                </form>
                <form asp-action="OdulSil" method="post" style="flex:1;display:contents;"
                      onsubmit="return confirm('@o.Name ödülünü silmek istediğinize emin misiniz?')">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="id" value="@o.Id">
                  <button type="submit" class="oy-btn-del">
                    <i class="ti ti-trash"></i> Sil
                  </button>
                </form>
              </div>
            </div>
          }
        </div>
      </div>
    }
  </div>

</div>

<script>
function selectIcon(icon, el) {
  document.querySelectorAll('.oy-icon-btn').forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('selectedIcon').value = icon;
}
</script>
